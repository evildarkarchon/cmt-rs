233: /// Fully collected Overview facts ready for the pure diagnostics builder.
234: #[derive(Debug, Default, Clone, PartialEq, Eq)]
235: pub struct OverviewCollectedFacts {
236:     /// Classified executable/DLL/BIN facts in reference display order.
237:     pub binaries: Vec<OverviewBinaryFact>,
238:     /// Classified BA2 records in deterministic path order.
239:     pub archives: Vec<ArchiveRecord>,
240:     /// Classified ESM/ESL/ESP records in deterministic path order.
241:     pub modules: Vec<ModuleRecord>,
242:     /// Required-file and enablement-file state.
243:     pub enablement: OverviewEnablementFacts,
244:     /// Safe collection diagnostics for logs, UI refresh state, or tests.
245:     pub diagnostics: OverviewCollectionDiagnostics,
246: }
247: 
248: /// High-level collector phase used by safe diagnostics.
249: #[derive(Debug, Clone, Copy, PartialEq, Eq, PartialOrd, Ord, Hash)]
250: pub enum OverviewCollectionPhase {
251:     /// Reference base executable/DLL/BIN classification.
252:     Binaries,
253:     /// Optional Data directory traversal.
254:     DataTraversal,
255:     /// Fallout4.ccc, plugins.txt, and INI enablement parsing.
256:     Enablement,
257:     /// Address Library bin existence check.
258:     AddressLibrary,
259:     /// BA2 header classification.
260:     Archives,
261:     /// ESM/ESL/ESP header classification.
262:     Modules,
263: }
264: 
265: impl OverviewCollectionPhase {
266:     /// Returns a stable lowercase phase label for logs and diagnostics.
267:     pub const fn as_str(self) -> &'static str {
268:         match self {
269:             Self::Binaries => "binaries",
270:             Self::DataTraversal => "data_traversal",
271:             Self::Enablement => "enablement",
272:             Self::AddressLibrary => "address_library",
273:             Self::Archives => "archives",
274:             Self::Modules => "modules",
275:         }
276:     }
277: }
278: 
279: /// Safe diagnostic category for a collector observation.
280: #[derive(Debug, Clone, Copy, PartialEq, Eq, PartialOrd, Ord, Hash)]
281: pub enum OverviewCollectionDiagnosticKind {
282:     /// An optional or required input was not present.
283:     Missing,
284:     /// An existing input could not be read.

