1294: /// Complete, UI-independent Overview snapshot.
1295: #[derive(Debug, Default, Clone, PartialEq, Eq)]
1296: pub struct OverviewSnapshot {
1297:     /// Last refresh lifecycle state.
1298:     pub refresh: OverviewRefreshState,
1299:     /// Top status rows derived from discovery and system metadata.
1300:     pub top: OverviewTopStatus,
1301:     /// Binary panel state.
1302:     pub binaries: BinaryPanelSummary,
1303:     /// Archive panel state.
1304:     pub archives: ArchivePanelSummary,
1305:     /// Module panel state.
1306:     pub modules: ModulePanelSummary,
1307:     /// Update banner state.
1308:     pub update_banner: UpdateBannerState,
1309:     /// Scanner-ready problem records.
1310:     pub problems: Vec<OverviewProblem>,
1311:     /// Last safe action error, such as a desktop-open failure.
1312:     pub last_action_error: Option<OverviewActionError>,
1313: }
1314: 
1315: impl OverviewSnapshot {
1316:     /// Creates an empty snapshot with labels/actions present and no OS access.
1317:     pub fn empty() -> Self {
1318:         Self::default()
1319:     }
1320: 
1321:     /// Creates a loading snapshot.
1322:     pub fn loading(message: impl Into<String>) -> Self {
1323:         Self {
1324:             refresh: OverviewRefreshState::loading(message),
1325:             ..Self::default()
1326:         }
1327:     }
1328: 
1329:     /// Creates a partial snapshot from already-safe data.
1330:     pub fn partial(message: impl Into<String>, problems: Vec<OverviewProblem>) -> Self {
1331:         Self {
1332:             refresh: OverviewRefreshState::partial(message),
1333:             problems,
1334:             ..Self::default()
1335:         }
1336:     }
