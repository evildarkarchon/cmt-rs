60: /// Input contract for the pure Overview diagnostic builder.
61: ///
62: /// Each field is pre-collected by another layer. The builder reads these facts
63: /// only; it does not attempt to repair, rescan, fetch updates, launch desktop
64: /// handlers, or infer file existence from paths.
65: pub struct OverviewDiagnosticsInput<'a> {
66:     /// Discovery report from the discovery service or a test fixture.
67:     pub discovery: &'a DiscoveryReport,
68:     /// Current typed application settings.
69:     pub settings: &'a AppSettings,
70:     /// Classified executable/DLL/BIN facts in display order.
71:     pub binaries: &'a [OverviewBinaryFact],
72:     /// Classified BA2 archive facts.
73:     pub archives: &'a [ArchiveRecord],
74:     /// Classified ESP/ESM/ESL module facts.
75:     pub modules: &'a [ModuleRecord],
76:     /// Injected enablement and required-file facts.
77:     pub enablement: &'a OverviewEnablementFacts,
78:     /// Update-check state supplied by a worker or test.
79:     pub update: &'a OverviewUpdateCheckState,
80:     /// Optional desktop action feedback from a previous UI action.
81:     pub last_desktop_action: Option<&'a OverviewDesktopActionFeedback>,
82: }
83: 
