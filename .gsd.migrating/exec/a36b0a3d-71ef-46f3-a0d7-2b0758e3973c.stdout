4:import { FluentPalette, FluentFontSettings } from "styling.slint";
5:import { FocusBorder } from "components.slint";
6:import { TabBarBase } from "../common/tabwidget-base.slint";
7:
8:export component TabWidgetImpl inherits Rectangle {
9:    in property <length> tabbar-preferred-height;
10:    in property <length> tabbar-preferred-width;
11:    in property <length> content-min-height;
12:    in property <length> content-min-width;
13:    in property <int> current-index;
14:    in property <int> current-focused;
15:    in property <Orientation> orientation:Orientation.horizontal;
16:    out property <length> content-x: orientation == Orientation.horizontal ? 0 : root.tabbar-preferred-width;
17:    out property <length> content-y: orientation == Orientation.horizontal ? root.tabbar-preferred-height : 0;
18:    out property <length> content-height:orientation == Orientation.horizontal ? root.height - root.tabbar-preferred-height : root.height;
19:    out property <length> content-width: orientation == Orientation.horizontal ? root.width : root.width - root.tabbar-preferred-width;
20:    out property <length> tabbar-x: 0;
21:    out property <length> tabbar-y: 0;
22:    out property <length> tabbar-height: orientation == Orientation.horizontal ? root.tabbar-preferred-height : root.height;
23:    out property <length> tabbar-width: orientation == Orientation.horizontal ? root.width : root.tabbar-preferred-width;
24:    preferred-width: root.content-min-width;
25:    min-width: max(root.content-min-width, root.tabbar-preferred-width);
26:    preferred-height: root.content-min-height + root.tabbar-preferred-height;
27:    min-height: root.content-min-height + root.tabbar-preferred-height;
28:}
29:
30:export component TabImpl inherits Rectangle {
31:    // The currently focused tab
32:    in property <int> current-focused;
33:    // The index of this tab
34:    in property <int> tab-index;
35:    // The total number of tabs
36:    in property <int> num-tabs;
37:    in property <string> title <=> i-text.text;
38:    in property <bool> enabled: true;
39:    out property <bool> has-focus: root.current-focused == root.tab-index;
40:    // The currently selected tab
41:    in-out property <int> current;
42:    private property <bool> hide-right-border: root.tab-index == root.num-tabs - 1 || tab-index + 1 == current;
43:    private property <bool> is-current: root.tab-index == root.current;
44:    min-width: max(32px, i-text.min-width);
45:    min-height: max(32px, i-text.min-height);
46:    horizontal-stretch: 0;
47:    vertical-stretch: 0;
48:    accessible-role: tab;
49:    accessible-enabled: root.enabled;
50:    accessible-label: root.title;
51:    accessible-item-index: root.tab-index;
52:    accessible-item-selectable: true;
53:    accessible-item-selected: root.is-current;
54:    accessible-action-default => {
55:        i-touch-area.clicked();
56:    }
57:    Rectangle {
58:        clip: true;
59:        width: 100%;
60:        height: 100%;
61:        i-background := Rectangle {
62:            y: 1px;
63:            width: 100%;
64:            height: parent.height + self.border-radius;
65:            border-radius: 7px;
66:            border-width: root.is-current ? 1px : 0px;
67:            border-color: FluentPalette.card-stroke;
68:            background: i-touch-area.pressed || root.is-current ? FluentPalette.layer-on-mica-base-alt : i-touch-area.has-hover ? FluentPalette.layer-on-mica-base-alt-secondary : transparent;
69:        }
70:    }
71:
72:    i-touch-area := TouchArea {
73:        enabled <=> root.enabled;
74:        clicked => {
75:            root.current = root.tab-index;
76:        }
77:    }
78:
79:    i-layout := HorizontalLayout {
80:        padding-left: 12px;
81:        padding-right: 12px;
82:        i-text := Text {
83:            vertical-alignment: center;
84:            horizontal-alignment: left;
85:            font-size: root.is-current ? FluentFontSettings.body-strong.font-size : FluentFontSettings.body.font-size;
86:            font-weight: root.is-current ? FluentFontSettings.body-strong.font-weight : FluentFontSettings.body.font-weight;
87:            color: root.is-current ? FluentPalette.control-foreground : FluentPalette.text-secondary;
88:            accessible-role: none;
89:        }
90:    }
91:
92:    if (!root.is-current && !root.hide-right-border && !i-touch-area.has-hover && !i-touch-area.pressed): Rectangle {
93:        x: (parent.width - self.width);
94:        width: 2px;
95:        height: 16px;
96:        background: FluentPalette.divider;
97:    }
98:    if (!root.is-current && !i-touch-area.has-hover && !i-touch-area.pressed): Rectangle {
99:        y: (parent.height - self.height);
100:        width: 100%;
101:        height: 1px;
102:        background: FluentPalette.divider;
103:    }
104:
105:    // focus border
106:    if (root.has-focus && root.enabled): FocusBorder {
107:        border-radius: i-background.border-radius;
108:    }
109:}
110:
111:component FluentTabBarBase inherits TabBarBase {
112:    // injected properties:
113:    // The currently focused tab
114:    in-out property <int> current-focused: i-focus-scope.has-focus ? i-focus-scope.focused-tab : -1;
115:    accessible-role: tab-list;
116:    accessible-delegate-focus: root.current-focused >= 0 ? root.current-focused : root.current;
117:    accessible-item-count: root.num-tabs;
118:    i-focus-scope := FocusScope {
119:        property <int> focused-tab: 0;
120:        x: 0;
121:        // Do not react on clicks
122:        width: 0px;
123:        key-pressed(event) => {
124:            if (event.text == "\n") {
125:                root.current = root.current-focused;
126:                return accept;
127:            }
128:            if (event.text == Key.LeftArrow) {
129:                self.focused-tab = Math.max(self.focused-tab - 1,  0);
130:                return accept;
131:            }
132:            if (event.text == Key.RightArrow) {
133:                self.focused-tab = Math.min(self.focused-tab + 1, root.num-tabs - 1);
134:                return accept;
135:            }
136:            return reject;
137:        }
138:        key-released(event) => {
139:            if (event.text == " ") {
140:                root.current = root.current-focused;
141:                return accept;
142:            }
143:            return reject;
144:        }
145:    }
146:}
147:
148:export component TabBarHorizontalImpl inherits FluentTabBarBase {
149:    Flickable {
150:        HorizontalLayout {
151:            @children
152:        }
153:    }
154:}
155:
156:export component TabBarVerticalImpl inherits FluentTabBarBase {
157:    Flickable {
158:        VerticalLayout {
159:            @children
160:        }
161:    }
162:}
163:
164:export component TabBarImpl inherits TabBarBase { }
165:
166:export component TabWidget inherits TabWidget { }
