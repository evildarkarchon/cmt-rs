284: class StdErr:
285: 	def __init__(self, root: Tk) -> None:
286: 		self.root = root
287: 		self.error_window: Toplevel | None = None
288: 		self.txt: Text
289: 		self.buffer: list[str] = []
290: 
291: 	def create_window(self) -> None:
292: 		if not self.error_window:
293: 			self.error_window = Toplevel(self.root)
294: 			self.error_window.wm_title("An Error Occurred")
295: 			self.error_window.wm_protocol("WM_DELETE_WINDOW", self.on_close)
296: 			self.txt = Text(self.error_window, width=120, height=25)
297: 			self.txt.pack(expand=True, fill=BOTH)
298: 
299: 	def write(self, string: str) -> int:
300: 		self.buffer.append(string)
301: 		return 0
302: 
303: 	def flush(self) -> None:
304: 		self.create_window()
305: 		buffer = "".join(self.buffer).strip()
306: 		self.buffer.clear()
307: 		if buffer:
308: 			self.txt.insert("insert", buffer)
309: 			logger.error("StdErr : %s", buffer)
310: 
311: 	def on_close(self) -> None:
312: 		if self.error_window:
313: 			self.error_window.destroy()
314: 			self.error_window = None

