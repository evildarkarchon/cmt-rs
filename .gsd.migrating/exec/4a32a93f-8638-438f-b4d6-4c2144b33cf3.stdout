771: 
772: impl DowngraderPreviewPlan {
773:     fn from_rows(
774:         request_id: u64,
775:         game_root: PathBuf,
776:         options: DowngraderOptionsSnapshot,
777:         status: DowngraderStatusSnapshot,
778:         rows: Vec<DowngraderPreviewPlanRow>,
779:     ) -> Self {
780:         let mut counts = DowngraderPreviewPlanCounts::default();
781:         for row in &rows {
782:             if row.failure.is_some() {
783:                 counts.failed_rows += 1;
784:             }
785:             if row.steps.iter().all(|step| {
786:                 matches!(
787:                     step.kind,
788:                     DowngraderPlanStepKind::SkipAlreadyDesired
789:                         | DowngraderPlanStepKind::SkipNotFound
790:                         | DowngraderPlanStepKind::SkipUnsupportedVersion

## stable_digest
-- 823: pub fn stable_digest(&self) -> String {
815:             can_execute,
816:         }
817:     }
818: 
819:     /// Returns a stable digest for the material file, backup, option, and step state in this plan.
820:     ///
821:     /// Request ids are intentionally excluded so a fresh revalidation can be compared with
822:     /// the exact preview the user reviewed before any destructive work starts.
823:     pub fn stable_digest(&self) -> String {
824:         let mut digest = Sha256::new();
825:         update_plan_digest_value(&mut digest, "cmt-rs-downgrader-preview-plan-v1");
826:         update_plan_digest_value(&mut digest, self.game_root.to_string_lossy().as_ref());
827:         update_plan_digest_value(&mut digest, self.options.target.as_reference_str());
828:         update_plan_digest_value(&mut digest, bool_digest_value(self.options.keep_backups));
829:         update_plan_digest_value(&mut digest, bool_digest_value(self.options.delete_deltas));
830:         update_plan_digest_value(&mut digest, bool_digest_value(self.can_execute));
831: 
832:         for row in &self.rows {
833:             update_plan_digest_value(&mut digest, row.plan.relative_path);
834:             update_plan_digest_value(&mut digest, row.plan.display_name);
835:             update_plan_digest_value(&mut digest, row.display_status.as_reference_str());
836:             update_plan_digest_value(&mut digest, row.current_crc32.as_deref().unwrap_or(""));
837:             update_plan_digest_value(&mut digest, row.current_path.to_string_lossy().as_ref());
838:             update_plan_digest_value(&mut digest, row.plan.target.as_reference_str());
839:             update_plan_digest_value(&mut digest, format!("{:?}", row.plan.action));
840:             update_plan_digest_value(&mut digest, &row.plan.current_backup_name);
841:             update_plan_digest_value(&mut digest, &row.plan.desired_backup_name);
842:             update_plan_digest_value(&mut digest, &row.plan.patch_name);
843:             update_plan_digest_value(&mut digest, &row.plan.patch_url);
844:             update_plan_digest_backup(&mut digest, row.desired_backup.as_ref());
845:             update_plan_digest_backup(&mut digest, row.current_backup.as_ref());
846:             update_plan_digest_value(&mut digest, row.failure.as_deref().unwrap_or(""));
847:             for step in &row.steps {
848:                 update_plan_digest_value(&mut digest, step.kind.as_str());
849:                 update_plan_digest_value(&mut digest, &step.message);
850:             }
851:         }
852: 
853:         format!("{:x}", digest.finalize())
854:     }
855: }
856: 
857: fn bool_digest_value(value: bool) -> &'static str {
858:     if value { "true" } else { "false" }

