2593: fn validate_game_root_path(root: &Path) -> Result<(), DowngraderServiceError> {
2594:     let has_component = root.components().next().is_some();
2595:     let has_parent = root
2596:         .components()
2597:         .any(|component| matches!(component, Component::ParentDir));
2598:     if !has_component || has_parent {
2599:         warn!(
2600:             event = "downgrader-root-unsafe",
2601:             root = %root.display(),
2602:             "Downgrader rejected unsafe game root"
2603:         );
2604:         return Err(DowngraderServiceError::InvalidGameRoot {
2605:             root: root.to_path_buf(),
2606:             safe_message: UNSAFE_ROOT_MESSAGE.to_owned(),
2607:         });
2608:     }
2609:     Ok(())
2610: }
