541: /// Bounded progress event emitted while downloading a patch for one file.
542: #[derive(Debug, Clone, PartialEq)]
543: pub struct DowngraderExecutionProgressEvent {
544:     /// Request id copied from the execution request.
545:     pub request_id: u64,
546:     /// Managed relative path whose patch is being downloaded.
547:     pub relative_path: &'static str,
548:     /// Patch asset name being downloaded.
549:     pub patch_name: String,
550:     /// Clamped reference progress value.
551:     pub progress: DowngraderProgress,
552: }
553: 
554: /// Per-file execution result and diagnostics.
555: #[derive(Debug, Clone, PartialEq, Eq)]
556: pub struct DowngraderExecutionFileResult {
557:     /// Managed relative path from the Fallout 4 root.
558:     pub relative_path: &'static str,
559:     /// Basename displayed in modal logs.
560:     pub display_name: &'static str,
561:     /// Final outcome for this file.
562:     pub outcome: DowngraderExecutionOutcome,
563:     /// User-visible log row emitted for this file.
564:     pub log_row: DowngraderExecutionLogRow,
565:     /// Safe diagnostics for tracing/tests, not modal text.
566:     pub diagnostics: Vec<String>,
567: }
568: 
569: /// Complete confirmed execution result.
570: #[derive(Debug, Clone, PartialEq)]
571: pub struct DowngraderExecutionResult {
572:     /// Request id copied from the execution request.
573:     pub request_id: u64,
574:     /// Validated game root used for all managed files.
575:     pub game_root: PathBuf,
576:     /// Confirmed options used for execution.

