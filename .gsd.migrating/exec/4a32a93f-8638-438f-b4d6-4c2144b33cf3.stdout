1366: impl<'a, F: Filesystem + WritableFilesystem + ?Sized> DowngraderService<'a, F> {
1367:     fn validated_execution_game_root(
1368:         &self,
1369:         planned_root: &Path,
1370:     ) -> Result<PathBuf, DowngraderServiceError> {
1371:         validate_game_root_path(planned_root)?;
1372:         let canonical_root = self
1373:             .filesystem
1374:             .canonicalize_path(planned_root)
1375:             .map_err(|error| {
1376:                 warn!(
1377:                     event = "downgrader-execute-root-canonicalize-failed",
1378:                     root = %planned_root.display(),
1379:                     failure_kind = ?error.kind,
1380:                     "Downgrader execution root canonicalization failed"
1381:                 );
1382:                 DowngraderServiceError::InvalidGameRoot {
1383:                     root: planned_root.to_path_buf(),
1384:                     safe_message: error.user_message().to_owned(),
1385:                 }
1386:             })?;
1387:         match self.filesystem.metadata(&canonical_root) {
1388:             Ok(metadata) if metadata.is_dir() => Ok(canonical_root),
1389:             Ok(_) => Err(DowngraderServiceError::InvalidGameRoot {
1390:                 root: canonical_root,
1391:                 safe_message: ROOT_NOT_DIRECTORY_MESSAGE.to_owned(),
1392:             }),
1393:             Err(error) if error.kind == PlatformErrorKind::NotFound => {
1394:                 Err(DowngraderServiceError::MissingGameRoot {
1395:                     safe_message: FALLOUT4_NOT_FOUND_MESSAGE.to_owned(),
1396:                 })
1397:             }
1398:             Err(error) => Err(DowngraderServiceError::InvalidGameRoot {
1399:                 root: canonical_root,
1400:                 safe_message: error.user_message().to_owned(),
1401:             }),
1402:         }
1403:     }
