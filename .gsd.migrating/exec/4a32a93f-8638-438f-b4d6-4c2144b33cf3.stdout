759:     pub game_root: PathBuf,
760:     /// User options used for this plan.
761:     pub options: DowngraderOptionsSnapshot,
762:     /// Status snapshot used as the source of truth for the plan.
763:     pub status: DowngraderStatusSnapshot,
764:     /// Six preview rows in reference patch order.
765:     pub rows: Vec<DowngraderPreviewPlanRow>,
766:     /// Aggregate row/step counts for diagnostics and UI summary text.
