## fn model_from_vec
1795: fn model_from_vec<T: Clone + 'static>(rows: Vec<T>) -> ModelRc<T> {
1796:     ModelRc::new(VecModel::from(rows))
1797: }
1798: 
1799: fn refresh_message(refresh: &OverviewRefreshState) -> String {
1800:     refresh
1801:         .message
1802:         .clone()
1803:         .unwrap_or_else(|| match refresh.phase {
1804:             domain::overview::OverviewRefreshPhase::Idle => {
1805:                 "Overview has not been refreshed.".to_owned()
1806:             }
1807:             domain::overview::OverviewRefreshPhase::Loading => "Refreshing Overview...".to_owned(),
1808:             domain::overview::OverviewRefreshPhase::Ready => "Overview refreshed.".to_owned(),
1809:             domain::overview::OverviewRefreshPhase::Partial => {
1810:                 "Overview refreshed with recoverable issues.".to_owned()
1811:             }
1812:             domain::overview::OverviewRefreshPhase::Error => "Overview refresh failed.".to_owned(),
1813:         })
1814: }
1815: 
1816: fn format_top_rows(snapshot: &OverviewSnapshot) -> Vec<OverviewUiRow> {
1817:     snapshot
1818:         .top
1819:         .rows()
1820:         .into_iter()
1821:         .map(format_top_row)
1822:         .collect()
1823: }
1824: 
1825: fn format_top_row(row: OverviewTopStatusRow) -> OverviewUiRow {
1826:     overview_ui_row(row.label, row.value, "", row.severity)
1827: }
1828: 
1829: fn format_binary_rows(snapshot: &OverviewSnapshot) -> Vec<OverviewUiRow> {
1830:     let mut rows = snapshot
1831:         .binaries
1832:         .rows
1833:         .iter()
1834:         .map(format_binary_row)
1835:         .collect::<Vec<_>>();
1836: 
1837:     if rows.is_empty() {
1838:         rows.push(overview_ui_row(
1839:             "Binaries",
1840:             "No binary facts collected yet.",
1841:             "",
1842:             StatusSeverity::Unknown,
1843:         ));
1844:     }
1845: 
1846:     rows.push(overview_ui_row(
1847:         "Address Library",
1848:         snapshot.binaries.address_library.display_text(),
1849:         "",
1850:         snapshot.binaries.address_library.severity(),
1851:     ));
1852:     rows
1853: }
1854: 
1855: fn format_binary_row(row: &BinaryStatusRow) -> OverviewUiRow {
1856:     overview_ui_row(
1857:         row.label.as_str(),
1858:         row.install_type.to_string(),
1859:         binary_detail(row),
1860:         row.severity,
1861:     )
1862: }
1863: 
1864: fn binary_detail(row: &BinaryStatusRow) -> String {
1865:     let mut parts = Vec::new();
1866:     if let Some(version) = row.version.as_deref().filter(|value| !value.is_empty()) {
1867:         parts.push(format!("Version: {version}"));
1868:     }
1869:     if let Some(hash) = row.hash.as_deref().filter(|value| !value.is_empty()) {
1870:         parts.push(format!("CRC32: {hash}"));
1871:     }
1872:     parts.join(" · ")
1873: }
1874: 
1875: fn format_count_panel_rows(rows: &[OverviewCountRow]) -> Vec<OverviewUiRow> {
1876:     if rows.is_empty() {
1877:         return vec![overview_ui_row(
1878:             "Counts",
1879:             "No facts collected yet.",
1880:             "",
1881:             StatusSeverity::Unknown,
1882:         )];
1883:     }
1884: 
1885:     rows.iter()
1886:         .map(|row| {
1887:             overview_ui_row(
1888:                 row.label,
1889:                 row.value.to_string(),
1890:                 row.limit
1891:                     .map(|limit| format!("Limit: {limit}"))
1892:                     .unwrap_or_default(),
1893:                 row.severity,
1894:             )
1895:         })
1896:         .collect()
1897: }
1898: 
1899: fn format_problem_summary(snapshot: &OverviewSnapshot) -> String {
1900:     format!("Problems: {}", snapshot.problems.len())
1901: }
1902: 
1903: fn format_problem_rows(snapshot: &OverviewSnapshot) -> Vec<OverviewUiRow> {
1904:     if snapshot.problems.is_empty() {
1905:         return vec![overview_ui_row(
1906:             "Problems",
1907:             "0",
1908:             "No problems detected.",
1909:             StatusSeverity::Good,
1910:         )];
1911:     }
1912: 
1913:     let mut rows = snapshot
1914:         .problems
1915:         .iter()
1916:         .take(5)
1917:         .map(format_problem_row)
1918:         .collect::<Vec<_>>();
1919:     if snapshot.problems.len() > 5 {
1920:         rows.push(overview_ui_row(
1921:             "More",
1922:             format!("+{} more", snapshot.problems.len() - 5),
1923:             "Open Scanner details in a later port slice.",
1924:             StatusSeverity::Info,

