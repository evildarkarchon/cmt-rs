## fn schedule_overview_action
1302: fn schedule_overview_action(
1303:     app: &MainWindow,
1304:     overview_controller: &Arc<Mutex<OverviewController>>,
1305:     worker_runtime: WorkerRuntime,
1306:     overview_sink: SlintEventLoopSink,
1307:     action_kind: OverviewDeferredActionKind,
1308:     unavailable_message: &'static str,
1309:     action_lookup: impl FnOnce(&OverviewController) -> Option<OverviewDeferredAction>,
1310: ) {
1311:     let action =
1312:         with_overview_controller_mut(overview_controller, |controller| action_lookup(controller))
1313:             .flatten();
1314: 
1315:     let Some(action) = action else {
1316:         apply_action_error(
1317:             app,
1318:             overview_controller,
1319:             action_kind,
1320:             unavailable_message.to_owned(),
1321:         );
1322:         return;
1323:     };
1324: 
1325:     tracing::info!(
1326:         event = "overview-desktop-action-schedule",
1327:         action = ?action.kind,
1328:         target = action_target_label(&action).as_str(),
1329:         "Scheduling Overview desktop action"
1330:     );
1331: 
1332:     let task = overview_desktop_task(action.kind);
1333:     if let Err(error) = worker_runtime.spawn_blocking_task(task, overview_sink, move |_context| {
1334:         execute_overview_action_payload(action)
1335:     }) {
1336:         tracing::error!(
1337:             event = "overview-desktop-action-spawn-failed",
1338:             action = ?action_kind,
1339:             error = %error,
1340:             "Overview desktop action worker could not be scheduled"
1341:         );
1342:         apply_action_error(
1343:             app,
1344:             overview_controller,
1345:             action_kind,
1346:             "Desktop action could not be started.".to_owned(),
1347:         );
1348:     }
1349: }
1350: 
1351: fn execute_overview_action_payload(action: OverviewDeferredAction) -> BlockingWorkerResult {
1352:     let action_kind = action.kind;
1353:     let service = OverviewLinkService::new(RealDesktopActions::new());
1354:     let feedback = service.execute(&action);
1355:     let (action, error) = action_error_from_feedback(feedback);
1356:     debug_assert_eq!(action, action_kind);
1357:     Ok(WorkerTaskOutcome::Completed(
1358:         overview_desktop_action_payload(action, error),
1359:     ))
1360: }
1361: 
1362: fn action_error_from_feedback(
1363:     feedback: OverviewDesktopActionFeedback,
1364: ) -> (OverviewDeferredActionKind, Option<OverviewActionError>) {
1365:     match feedback.outcome {
1366:         OverviewDesktopActionOutcome::Succeeded => (feedback.action, None),
1367:         OverviewDesktopActionOutcome::Failed { safe_message } => (
1368:             feedback.action,
1369:             Some(OverviewActionError::new(feedback.action, safe_message)),
1370:         ),
1371:     }
1372: }
1373: 
1374: fn apply_action_error(
1375:     app: &MainWindow,
1376:     overview_controller: &Arc<Mutex<OverviewController>>,
1377:     action: OverviewDeferredActionKind,
1378:     message: String,
1379: ) {
1380:     with_overview_controller_mut(overview_controller, |controller| {
1381:         controller
1382:             .desktop_action_completed(action, Some(unavailable_action_error(action, message)));
1383:     });
1384:     apply_current_overview_snapshot(app, overview_controller);
1385: }
1386: 
1387: fn apply_tools_feedback(
1388:     app: &MainWindow,
