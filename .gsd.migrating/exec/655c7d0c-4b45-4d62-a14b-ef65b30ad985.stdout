1390:     feedback: ToolsActionFeedback,
1391: ) {
1392:     with_tools_controller_mut(controller, |controller| {
1393:         controller.handle_feedback(feedback);
1394:     });
1395:     apply_current_tools_state(app, controller);
1396: }
