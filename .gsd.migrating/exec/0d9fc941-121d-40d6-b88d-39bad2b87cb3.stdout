1239: fn schedule_overview_update_check(
1240:     request: app::overview_controller::OverviewRefreshRequest,
1241:     overview_sink: SlintEventLoopSink,
1242:     runtime_handle: tokio::runtime::Handle,
1243: ) {
1244:     if !request.should_check_updates() {
1245:         tracing::debug!(
1246:             event = "overview-update-skipped",
1247:             refresh_id = request.refresh_id,
1248:             update_source = request.update_source.as_wire_value(),
1249:             "Overview update check skipped by settings"
1250:         );
1251:         return;
1252:     }
1253: 
1254:     let task = request.update_task();
1255:     emit_worker_event_or_log(&overview_sink, WorkerEvent::running(task.clone()));
1256: 
1257:     runtime_handle.spawn(async move {
1258:         let banner = match RealUpdateCheckClient::new() {
1259:             Ok(client) => {
1260:                 let service = UpdateCheckService::new(client);
1261:                 service.check(request.update_source).await.banner_state()
