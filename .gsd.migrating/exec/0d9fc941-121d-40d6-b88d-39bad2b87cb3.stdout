1263:             Err(error) => {
1264:                 tracing::warn!(
1265:                     event = "overview-update-client-build-failed",
1266:                     refresh_id = request.refresh_id,
1267:                     error = %error,
1268:                     "Overview update client could not be created; failing silently"
1269:                 );
1270:                 update_failure_banner(request.update_source, "update client could not be created")
1271:             }

