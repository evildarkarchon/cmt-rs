## /home/evild/.cargo/registry/src/index.crates.io-1949cf8c6b5b557f/pelite-0.10.0/examples/readme.rs
-- 1-80
1:/*!
2:The code from the readme, try me out with `cargo run --example readme`.
3: */
4:
5:use pelite::FileMap;
6:use pelite::pe64::{Pe, PeFile};
7:
8:fn main() {
9:	// Load the desired file into memory
10:	let file_map = FileMap::open("demo/Demo64.dll").unwrap();
11:	// Process the image file
12:	dll_deps(file_map.as_ref()).unwrap();
13:}
14:
15:fn dll_deps(image: &[u8]) -> pelite::Result<()> {
16:	// Interpret the bytes as a PE32+ executable
17:	let file = PeFile::from_bytes(image)?;
18:
19:	// Let's read the DLL dependencies
20:	let imports = file.imports()?;
21:	for desc in imports {
22:		// Get the DLL name being imported from
23:		let dll_name = desc.dll_name()?;
24:		// Get the number of imports for this dll
25:		let iat = desc.iat()?;
26:		println!("imported {} functions from {}", iat.len(), dll_name);
27:	}
28:
29:	Ok(())
30:}
