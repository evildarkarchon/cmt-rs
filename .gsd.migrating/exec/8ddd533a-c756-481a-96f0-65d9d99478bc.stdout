503:     /// Optional absolute path for scanner/problem handoff.
504:     pub path: Option<PathBuf>,
505:     /// Classified install type for this binary.
506:     pub install_type: Fallout4InstallType,
507:     /// Optional version string displayed on hover by the reference UI.
508:     pub version: Option<String>,
509:     /// Optional CRC/hash fallback displayed on hover by the reference UI.
510:     pub hash: Option<String>,
511:     /// Severity/color intent for the row.
512:     pub severity: StatusSeverity,
513: }
514: 
515: impl BinaryStatusRow {
516:     /// Creates a binary status row from already-classified file information.
517:     pub fn new(label: impl Into<String>, install_type: Fallout4InstallType) -> Self {
518:         Self {
519:             label: label.into(),
520:             path: None,
521:             install_type,
522:             version: None,
523:             hash: None,
524:             severity: install_type_severity(install_type),
525:         }
526:     }
---
532:     }
533: 
534:     /// Attaches optional version/hash metadata to this binary row.
535:     pub fn with_version_metadata(
536:         mut self,
537:         version: impl Into<Option<String>>,
538:         hash: impl Into<Option<String>>,
539:     ) -> Self {
540:         self.version = version.into();
541:         self.hash = hash.into();
542:         self
543:     }
544: }
