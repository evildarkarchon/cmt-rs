226:     /// The serialized object is produced by the domain model, so unknown keys are
227:     /// never persisted and later UI/controller code can revert state if this file
228:     /// write fails.
229:     pub fn save(&self, settings: &AppSettings) -> io::Result<()> {
230:         let mut json =
231:             serde_json::to_string_pretty(&settings.to_json_value()).map_err(io::Error::other)?;
232:         json.push('\n');
233:         fs::write(&self.paths.settings_path, json)
234:     }
235: }
