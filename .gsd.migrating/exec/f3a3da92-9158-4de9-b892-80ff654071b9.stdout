386: fn load_settings_controller() -> SettingsController<FileAssetResolver> {
387:     SettingsController::load(SettingsStore::production()).unwrap_or_else(|error| {
388:         tracing::error!(%error, "Settings : Failed to load settings; using in-memory defaults");
389:         SettingsController::from_settings(SettingsStore::production(), AppSettings::default())
390:     })
391: }
