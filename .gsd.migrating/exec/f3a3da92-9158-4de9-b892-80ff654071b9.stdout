254: #[derive(Debug, Clone, Copy, PartialEq, Eq)]
255: enum DowngraderOpenSource {
256:     Overview,
257:     Tools,
258: }
259: 
260: impl DowngraderOpenSource {
261:     const fn label(self) -> &'static str {
262:         match self {
263:             Self::Overview => "overview",
264:             Self::Tools => "tools",
265:         }
266:     }
267: }
