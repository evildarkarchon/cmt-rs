341: /// Parsed key/value contents for a single Fallout 4 INI file.
342: #[derive(Debug, Default, Clone, PartialEq, Eq)]
343: pub struct IniDocument {
344:     /// Optional source path used for diagnostics and later reload operations.
345:     pub source_path: Option<PathBuf>,
346:     /// Lowercase section names mapped to lowercase setting keys and raw values.
347:     pub sections: BTreeMap<String, BTreeMap<String, String>>,
348: }
349: 
350: impl IniDocument {
351:     /// Creates an empty INI document with an optional source path.
352:     pub fn new(source_path: Option<impl Into<PathBuf>>) -> Self {
353:         Self {
354:             source_path: source_path.map(Into::into),
355:             sections: BTreeMap::new(),
356:         }
357:     }
358: 
