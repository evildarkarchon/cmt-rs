## struct ModuleRecord
296: 
297: /// Single plugin/module record carried by scanner and overview workflows.
298: #[derive(Debug, Clone, PartialEq, Eq, Hash)]
299: pub struct ModuleRecord {
300:     /// Module path as discovered by a platform/scanner adapter.
301:     pub path: PathBuf,
302:     /// Full or light module classification.
303:     pub kind: ModuleKind,
304:     /// Parsed HEDR/header version.
305:     pub header_version: ModuleHeaderVersion,
306:     /// Whether plugin enablement parsing found this module active.
307:     pub enabled: bool,
308:     /// Whether the scanner could read enough bytes to classify the module.
309:     pub readable: bool,
310: }
311: 
312: impl ModuleRecord {
313:     /// Creates a readable module record with explicit enablement state.
314:     pub fn new(
315:         path: impl Into<PathBuf>,
316:         kind: ModuleKind,
317:         header_version: ModuleHeaderVersion,
318:         enabled: bool,
319:     ) -> Self {
320:         Self {
321:             path: path.into(),
322:             kind,
323:             header_version,
324:             enabled,
325:             readable: true,
326:         }
327:     }
328: 
329:     /// Creates an unreadable module record while preserving its path.
330:     pub fn unreadable(path: impl Into<PathBuf>) -> Self {
331:         Self {
332:             path: path.into(),
333:             kind: ModuleKind::Full,
334:             header_version: ModuleHeaderVersion::Unknown(String::new()),
335:             enabled: false,
336:             readable: false,
337:         }
338:     }
339: }
