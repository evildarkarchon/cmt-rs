211: /// Input request for [`OverviewCollector::collect`].
212: #[derive(Debug, Clone, Copy)]
213: pub struct OverviewCollectionRequest<'a> {
214:     /// Installation discovered by the discovery service.
215:     pub installation: &'a Fallout4Installation,
216:     /// Pre-resolved environment paths used for enablement files.
217:     pub environment: &'a OverviewCollectionEnvironment,
218: }
219: 
220: impl<'a> OverviewCollectionRequest<'a> {
221:     /// Creates a collection request for a discovered Fallout 4 installation.
222:     pub const fn new(
223:         installation: &'a Fallout4Installation,
224:         environment: &'a OverviewCollectionEnvironment,
225:     ) -> Self {
226:         Self {
227:             installation,
228:             environment,
229:         }
230:     }
231: }
