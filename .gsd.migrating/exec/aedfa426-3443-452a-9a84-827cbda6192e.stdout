## impl OverviewCollector
## pub fn collect
395:     /// Collects typed facts for a single Overview refresh.
396:     ///
397:     /// This method is intentionally infallible: malformed, missing, and
398:     /// permission-denied inputs are converted into typed records or safe
399:     /// diagnostics rather than panics or modal warnings.
400:     pub fn collect(&self, request: OverviewCollectionRequest<'_>) -> OverviewCollectedFacts {
401:         let span = info_span!(
402:             "overview_collector.collect",
403:             game_path = %request.installation.game_path.display()
404:         );
405:         let _guard = span.enter();
406:         debug!("overview filesystem collection started");
407: 
408:         let mut diagnostics = OverviewCollectionDiagnostics::default();
409:         let mut binaries = self.collect_binaries(request.installation, &mut diagnostics);
410:         let detected_install_type = detected_install_type_from_binaries(&binaries);
411:         let data_index = self.collect_data_index(request.installation, &mut diagnostics);
412:         let enablement_inputs = self.collect_enablement(
413:             request.installation,
414:             request.environment,
415:             data_index.as_ref(),
416:             detected_install_type,
417:             &mut diagnostics,
418:         );
419:         let archives = self.collect_archives(
420:             data_index.as_ref(),
421:             &enablement_inputs.enabled_archives,
422:             &mut diagnostics,
423:         );
424:         let modules = self.collect_modules(
425:             data_index.as_ref(),
426:             &enablement_inputs.enabled_modules,
427:             &mut diagnostics,
428:         );
429: 
430:         diagnostics.binary_count = binaries.len();
431:         diagnostics.archive_count = archives.len();
432:         diagnostics.module_count = modules.len();
433:         diagnostics.enabled_archive_count = archives.iter().filter(|record| record.enabled).count();
434:         diagnostics.enabled_module_count = modules.iter().filter(|record| record.enabled).count();
435:         diagnostics.record_phase(OverviewCollectionPhase::Binaries, binaries.len());
436:         diagnostics.record_phase(OverviewCollectionPhase::Archives, archives.len());
437:         diagnostics.record_phase(OverviewCollectionPhase::Modules, modules.len());
438: 
439:         normalize_binary_order(&mut binaries);
440: 
441:         debug!(
442:             binary_count = diagnostics.binary_count,
443:             archive_count = diagnostics.archive_count,
444:             module_count = diagnostics.module_count,
445:             enabled_archive_count = diagnostics.enabled_archive_count,
446:             enabled_module_count = diagnostics.enabled_module_count,
447:             missing_file_count = diagnostics.missing_file_count,
448:             unreadable_file_count = diagnostics.unreadable_file_count,
449:             "overview filesystem collection completed"
450:         );
451: 
452:         OverviewCollectedFacts {
453:             binaries,
454:             archives,
455:             modules,
456:             enablement: enablement_inputs.facts,
457:             diagnostics,
458:         }
459:     }
460: 
461:     fn collect_binaries(
462:         &self,
463:         installation: &Fallout4Installation,
464:         diagnostics: &mut OverviewCollectionDiagnostics,
465:     ) -> Vec<OverviewBinaryFact> {
466:         let mut facts = Vec::with_capacity(BASE_FILES.len());
467:         let mut detected_game_type = Fallout4InstallType::Unknown;
468: 
469:         for definition in BASE_FILES {
470:             let path = join_relative_path(&installation.game_path, definition.relative_path);
471:             let mut fact = self.collect_binary(definition, &path, diagnostics);
472: 
473:             if path_basename_eq(definition.relative_path, "Fallout4.exe") {
474:                 self.apply_downgrade_detection(installation, &mut fact, diagnostics);
475:                 detected_game_type = fact.install_type;
476:             } else if fact.install_type == Fallout4InstallType::NextGenAnniversary
477:                 && matches!(
478:                     detected_game_type,
479:                     Fallout4InstallType::NextGen | Fallout4InstallType::Anniversary
480:                 )
