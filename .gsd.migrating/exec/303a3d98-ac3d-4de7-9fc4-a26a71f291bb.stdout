444: fn bind_downgrader_worker_sink(
445:     app: &MainWindow,
446:     window: &DowngraderWindow,
447:     controller: Arc<Mutex<DowngraderController>>,
448:     overview_controller: Arc<Mutex<OverviewController>>,
449:     shared_settings_snapshot: Arc<Mutex<AppSettings>>,
450:     worker_runtime: WorkerRuntime,
451:     overview_sink: SlintEventLoopSink,
452:     runtime_handle: tokio::runtime::Handle,
453: ) -> SlintEventLoopSink {
454:     let app = app.as_weak();
455:     let window = window.as_weak();
456:     SlintEventLoopSink::new(move |event| {
457:         let task_id = event.task.id.to_string();
458:         let task_kind = event.task.kind.label();
459:         let status = event.status.label();
460:         let was_run_completion = matches!(
461:             &event.payload,
462:             WorkerPayload::Downgrader(workers::DowngraderWorkerPayload::RunCompleted { .. })
463:         );
464:         let Some(window) = window.upgrade() else {
465:             tracing::warn!(
466:                 event = "s09-downgrader-worker-event-dropped",
467:                 task_id = %task_id,
468:                 task_kind,
469:                 status,
470:                 "Downgrader worker event arrived after the Slint window was gone"
471:             );
472:             return;
473:         };
474: 
475:         let Some(result) = with_downgrader_controller_mut(&controller, |controller| {
476:             handle_downgrader_worker_event(controller, event)
477:         }) else {
478:             return;
479:         };
480: 
481:         match result {
482:             DowngraderTransitionResult::Applied => {
483:                 tracing::debug!(
484:                     event = "s09-downgrader-worker-event-applied",
485:                     task_id = %task_id,
486:                     task_kind,
487:                     status,
488:                     "Downgrader worker event applied to render state"
489:                 );
490:                 apply_current_downgrader_state(&window, &controller);
491:                 if was_run_completion {
492:                     let app_handle = app.upgrade();
493:                     let overview_settings =
494:                         overview_settings_for_downgrader_completion(&shared_settings_snapshot);
495:                     schedule_downgrader_completion_refresh(
496:                         app_handle.as_ref(),
497:                         &window,
498:                         &controller,
499:                         &overview_controller,
500:                         overview_settings,
501:                         worker_runtime,
502:                         overview_sink.clone(),
503:                         runtime_handle.clone(),
504:                     );
505:                 }
506:             }
507:             DowngraderTransitionResult::StaleIgnored => tracing::debug!(
508:                 event = "s09-downgrader-worker-event-stale-ignored",
509:                 task_id = %task_id,
510:                 task_kind,
511:                 status,
512:                 "Downgrader worker event was stale and ignored"
513:             ),
514:             DowngraderTransitionResult::Ignored => tracing::debug!(
515:                 event = "s09-downgrader-worker-event-ignored",
516:                 task_id = %task_id,
517:                 task_kind,
518:                 status,
519:                 "Ignoring non-Downgrader worker event on Downgrader sink"
520:             ),
521:             DowngraderTransitionResult::Rejected | DowngraderTransitionResult::CloseBlocked => {
522:                 tracing::debug!(
523:                     event = "s09-downgrader-worker-event-rejected",
524:                     task_id = %task_id,
525:                     task_kind,
526:                     status,
527:                     result = ?result,
528:                     "Downgrader worker event was rejected by current modal state"
529:                 );
530:             }
531:         }
532:     })
533: }
