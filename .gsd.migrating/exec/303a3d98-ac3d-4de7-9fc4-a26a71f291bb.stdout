386: fn load_settings_controller() -> SettingsController<FileAssetResolver> {
387:     SettingsController::load(SettingsStore::production()).unwrap_or_else(|error| {
388:         tracing::error!(%error, "Settings : Failed to load settings; using in-memory defaults");
389:         SettingsController::from_settings(SettingsStore::production(), AppSettings::default())
390:     })
391: }
392: 
393: fn bind_settings_callbacks(
394:     app: &MainWindow,
395:     controller: Rc<RefCell<SettingsController<FileAssetResolver>>>,
396:     shared_settings_snapshot: Arc<Mutex<AppSettings>>,
397: ) {
398:     app.on_update_source_selected({
399:         let app = app.as_weak();
400:         let controller = Rc::clone(&controller);
401:         let shared_settings_snapshot = Arc::clone(&shared_settings_snapshot);
402: 
403:         move |selected| {
404:             let visible_value = controller
405:                 .borrow_mut()
406:                 .select_update_source(selected.as_str());
407:             remember_current_settings_snapshot(&controller, &shared_settings_snapshot);
408:             if let Some(app) = app.upgrade() {
409:                 app.set_update_source(visible_value.into());
410:             }
411:         }
412:     });
413: 
414:     app.on_log_level_selected({
415:         let app = app.as_weak();
416:         let controller = Rc::clone(&controller);
417:         let shared_settings_snapshot = Arc::clone(&shared_settings_snapshot);
418: 
419:         move |selected| {
420:             let visible_value = controller.borrow_mut().select_log_level(selected.as_str());
421:             remember_current_settings_snapshot(&controller, &shared_settings_snapshot);
422:             if let Some(app) = app.upgrade() {
423:                 app.set_log_level(visible_value.into());
424:             }
425:         }
426:     });
427: }
428: 
429: fn remember_current_settings_snapshot<R: AssetResolver>(
430:     controller: &Rc<RefCell<SettingsController<R>>>,
431:     shared_settings_snapshot: &Arc<Mutex<AppSettings>>,
432: ) {
433:     let settings = controller.borrow().current_settings().clone();
434:     match shared_settings_snapshot.lock() {
435:         Ok(mut snapshot) => *snapshot = settings,
436:         Err(error) => tracing::error!(
437:             event = "settings-shared-snapshot-update-failed",
438:             diagnostic = %error,
439:             "Current settings snapshot could not be updated"
440:         ),
441:     }
442: }
