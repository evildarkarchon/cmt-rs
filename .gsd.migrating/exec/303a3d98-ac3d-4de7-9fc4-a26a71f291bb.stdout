756: fn bind_tools_callbacks(
757:     app: &MainWindow,
758:     downgrader_window: &DowngraderWindow,
759:     controller: Arc<Mutex<ToolsController>>,
760:     downgrader_controller: Arc<Mutex<DowngraderController>>,
761:     settings_controller: Rc<RefCell<SettingsController<FileAssetResolver>>>,
762:     worker_runtime: WorkerRuntime,
763:     tools_sink: SlintEventLoopSink,
764:     downgrader_sink: SlintEventLoopSink,
765: ) {
766:     app.on_tool_action_requested({
767:         let app = app.as_weak();
768:         let downgrader_window = downgrader_window.as_weak();
769:         let controller = Arc::clone(&controller);
770:         let downgrader_controller = Arc::clone(&downgrader_controller);
771:         let settings_controller = Rc::clone(&settings_controller);
772:         let downgrader_sink = downgrader_sink.clone();
773: 
774:         move |action_id| {
775:             let action_id = action_id.to_string();
776:             if action_id == ToolActionId::DowngradeManager.as_str() {
777:                 if let Some(downgrader_window) = downgrader_window.upgrade() {
778:                     request_open_downgrader_modal(
779:                         &downgrader_window,
780:                         &downgrader_controller,
781:                         &settings_controller,
782:                         worker_runtime,
783:                         downgrader_sink.clone(),
784:                         DowngraderOpenSource::Tools,
785:                     );
786:                 }
787:                 return;
788:             }
789: 
790:             if let Some(app) = app.upgrade() {
791:                 request_tools_action(
792:                     &app,
793:                     &controller,
794:                     worker_runtime,
795:                     tools_sink.clone(),
796:                     action_id,
797:                 );
798:             }
799:         }
800:     });
801: 
802:     app.on_tools_open_downgrade_manager_requested({
803:         let downgrader_window = downgrader_window.as_weak();
804:         let downgrader_controller = Arc::clone(&downgrader_controller);
805:         let settings_controller = Rc::clone(&settings_controller);
806:         let downgrader_sink = downgrader_sink.clone();
807: 
808:         move || {
809:             if let Some(downgrader_window) = downgrader_window.upgrade() {
810:                 request_open_downgrader_modal(
811:                     &downgrader_window,
812:                     &downgrader_controller,
813:                     &settings_controller,
814:                     worker_runtime,
815:                     downgrader_sink.clone(),
816:                     DowngraderOpenSource::Tools,
817:                 );
818:             }
819:         }
820:     });
821: }
