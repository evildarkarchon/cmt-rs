1592: fn request_open_downgrader_modal<R: AssetResolver>(
1593:     window: &DowngraderWindow,
1594:     controller: &Arc<Mutex<DowngraderController>>,
1595:     settings_controller: &Rc<RefCell<SettingsController<R>>>,
1596:     worker_runtime: WorkerRuntime,
1597:     downgrader_sink: SlintEventLoopSink,
1598:     source: DowngraderOpenSource,
1599: ) {
1600:     let settings_snapshot = settings_controller
1601:         .borrow()
1602:         .current_downgrader_settings()
1603:         .clone();
1604:     let Some(request) = with_downgrader_controller_mut(controller, |controller| {
1605:         controller.open(settings_snapshot, None)
1606:     })
1607:     .flatten() else {
1608:         apply_current_downgrader_state(window, controller);
1609:         return;
1610:     };
1611: 
1612:     tracing::info!(
1613:         event = "s09-downgrader-open-schedule",
1614:         source = source.label(),
1615:         request_id = request.request_id,
1616:         task_id = %request.task.id,
1617:         "Scheduling Downgrader status worker after modal open"
1618:     );
1619:     if let Err(error) = window.show() {
1620:         tracing::warn!(
1621:             event = "s09-downgrader-show-failed",
1622:             source = source.label(),
1623:             diagnostic = %error,
1624:             "Downgrader modal show failed"
1625:         );
1626:     }
1627:     apply_current_downgrader_state(window, controller);
1628:     schedule_downgrader_status_request(
1629:         window,
1630:         controller,
1631:         worker_runtime,
1632:         downgrader_sink,
1633:         request,
1634:     );
1635: }
1636: 
1637: fn request_downgrader_patch_or_run<R: AssetResolver>(
1638:     window: &DowngraderWindow,
1639:     controller: &Arc<Mutex<DowngraderController>>,
1640:     settings_controller: &Rc<RefCell<SettingsController<R>>>,
1641:     shared_settings_snapshot: &Arc<Mutex<AppSettings>>,
1642:     worker_runtime: WorkerRuntime,
1643:     downgrader_sink: SlintEventLoopSink,
1644: ) {
1645:     let Some(options) =
1646:         with_downgrader_controller_mut(controller, |controller| controller.options())
1647:     else {
1648:         return;
1649:     };
1650:     let save_result = settings_controller
1651:         .borrow_mut()
1652:         .save_downgrader_settings_for_workflow(downgrader_settings_from_options(options));
1653:     if !save_result.should_schedule_workflow() {
1654:         tracing::warn!(
1655:             event = "s09-downgrader-workflow-not-scheduled",
1656:             reason = "settings-save-failed",
1657:             "Downgrader work not scheduled because settings persistence failed"
1658:         );
1659:         with_downgrader_controller_mut(controller, |controller| {
1660:             controller.set_keep_backups(save_result.visible_settings.keep_backups);
1661:             controller.set_delete_deltas(save_result.visible_settings.delete_deltas);
1662:         });
1663:         apply_current_downgrader_state(window, controller);
1664:         return;
1665:     }
1666:     remember_current_settings_snapshot(settings_controller, shared_settings_snapshot);
1667: 
1668:     let Some(request) =
1669:         with_downgrader_controller_mut(controller, |controller| controller.request_patch_all())
1670:             .flatten()
1671:     else {
1672:         apply_current_downgrader_state(window, controller);
1673:         return;
1674:     };
1675:     apply_current_downgrader_state(window, controller);
1676: 
1677:     match request {
1678:         DowngraderPatchWorkerRequest::PreviewPlan(request) => {
1679:             schedule_downgrader_plan_request(
1680:                 window,
1681:                 controller,
1682:                 worker_runtime,
1683:                 downgrader_sink,
1684:                 request,
1685:             );
1686:         }
1687:         DowngraderPatchWorkerRequest::ConfirmedRun(request) => {
1688:             schedule_downgrader_run_request(
1689:                 window,
1690:                 controller,
1691:                 worker_runtime,
1692:                 downgrader_sink,
1693:                 request,
1694:             );
1695:         }
1696:     }
1697: }
1698: 
1699: fn schedule_downgrader_status_request(
1700:     window: &DowngraderWindow,
1701:     controller: &Arc<Mutex<DowngraderController>>,
1702:     worker_runtime: WorkerRuntime,
1703:     downgrader_sink: SlintEventLoopSink,
1704:     request: DowngraderStatusWorkerRequest,
1705: ) {
1706:     let request_id = request.request_id;
1707:     let task = request.task.clone();
1708:     let task_for_failure = task.clone();
1709:     tracing::info!(
1710:         event = "s09-downgrader-status-schedule",
1711:         request_id,
1712:         task_id = %task.id,
1713:         "Scheduling Downgrader status worker"
1714:     );
1715:     if let Err(error) = worker_runtime.spawn_blocking_task(task, downgrader_sink, move |_context| {
1716:         build_downgrader_status_payload(request)
1717:     }) {
1718:         tracing::error!(
1719:             event = "s09-downgrader-status-spawn-failed",
1720:             request_id,
1721:             task_id = %task_for_failure.id,
1722:             error = %error,
1723:             "Downgrader status worker could not be scheduled"
1724:         );
1725:         with_downgrader_controller_mut(controller, |controller| {
1726:             controller.spawn_failed(DowngraderWorkerRequestKind::Status, request_id, error);
1727:         });
1728:         apply_current_downgrader_state(window, controller);
1729:     }
1730: }
1731: 
1732: fn schedule_downgrader_plan_request(
1733:     window: &DowngraderWindow,
1734:     controller: &Arc<Mutex<DowngraderController>>,
1735:     worker_runtime: WorkerRuntime,
1736:     downgrader_sink: SlintEventLoopSink,
1737:     request: DowngraderPlanWorkerRequest,
1738: ) {
1739:     let request_id = request.request_id;
1740:     let task = request.task.clone();
1741:     let task_for_failure = task.clone();
1742:     tracing::info!(
1743:         event = "s09-downgrader-plan-schedule",
1744:         request_id,
1745:         task_id = %task.id,
1746:         "Scheduling Downgrader plan worker"
1747:     );
1748:     if let Err(error) = worker_runtime.spawn_blocking_task(task, downgrader_sink, move |_context| {
1749:         build_downgrader_plan_payload(request)
1750:     }) {
1751:         tracing::error!(
1752:             event = "s09-downgrader-plan-spawn-failed",
1753:             request_id,
1754:             task_id = %task_for_failure.id,
1755:             error = %error,
1756:             "Downgrader plan worker could not be scheduled"
1757:         );
1758:         with_downgrader_controller_mut(controller, |controller| {
1759:             controller.spawn_failed(DowngraderWorkerRequestKind::Plan, request_id, error);
1760:         });
1761:         apply_current_downgrader_state(window, controller);
1762:     }
1763: }
1764: 
1765: fn schedule_downgrader_run_request(
1766:     window: &DowngraderWindow,
1767:     controller: &Arc<Mutex<DowngraderController>>,
1768:     worker_runtime: WorkerRuntime,
1769:     downgrader_sink: SlintEventLoopSink,
1770:     request: DowngraderRunWorkerRequest,
1771: ) {
1772:     let request_id = request.request_id;
1773:     let task = request.task.clone();
1774:     let task_for_failure = task.clone();
1775:     tracing::info!(
1776:         event = "s09-downgrader-run-schedule",
1777:         request_id,
1778:         confirmed_plan_request_id = request.confirmed_plan_request_id,
1779:         task_id = %task.id,
1780:         "Scheduling Downgrader confirmed run worker"
1781:     );
1782:     if let Err(error) = worker_runtime.spawn_blocking_task(task, downgrader_sink, move |context| {
1783:         build_downgrader_run_payload(context, request)
1784:     }) {
1785:         tracing::error!(
1786:             event = "s09-downgrader-run-spawn-failed",
1787:             request_id,
1788:             task_id = %task_for_failure.id,
1789:             error = %error,
1790:             "Downgrader run worker could not be scheduled"
1791:         );
1792:         with_downgrader_controller_mut(controller, |controller| {
1793:             controller.spawn_failed(DowngraderWorkerRequestKind::Run, request_id, error);
1794:         });
1795:         apply_current_downgrader_state(window, controller);
1796:     }
1797: }
1798: 
1799: fn overview_settings_for_downgrader_completion(
1800:     shared_settings_snapshot: &Arc<Mutex<AppSettings>>,
1801: ) -> AppSettings {
1802:     match shared_settings_snapshot.lock() {
1803:         Ok(settings) => settings.clone(),
1804:         Err(error) => {
1805:             tracing::error!(
1806:                 event = "s09-downgrader-overview-settings-unavailable",
1807:                 diagnostic = %error,
1808:                 "Current settings snapshot unavailable; using safe defaults for Overview refresh"
1809:             );
1810:             AppSettings::default()
1811:         }
1812:     }
1813: }
1814: 
1815: fn schedule_downgrader_completion_refresh(
1816:     app: Option<&MainWindow>,
1817:     window: &DowngraderWindow,
1818:     controller: &Arc<Mutex<DowngraderController>>,
1819:     overview_controller: &Arc<Mutex<OverviewController>>,
1820:     overview_settings: AppSettings,
1821:     worker_runtime: WorkerRuntime,
1822:     overview_sink: SlintEventLoopSink,
1823:     runtime_handle: tokio::runtime::Handle,
1824: ) {
1825:     if let Some(status_request) = with_downgrader_controller_mut(controller, |controller| {
1826:         controller.take_pending_status_refresh()
1827:     })
1828:     .flatten()
1829:     {
1830:         schedule_downgrader_status_request(
1831:             window,
1832:             controller,
1833:             worker_runtime,
1834:             bind_downgrader_worker_sink_for_status_only(window, Arc::clone(controller)),
1835:             status_request,
1836:         );
1837:     }
1838: 
1839:     if let Some(app) = app {
1840:         tracing::info!(
1841:             event = "s09-downgrader-overview-refresh-requested",
1842:             "Requesting Overview refresh after Downgrader completion"
1843:         );
1844:         request_overview_refresh_from_settings(
1845:             app,
1846:             overview_controller,
1847:             overview_settings,
1848:             worker_runtime,
1849:             overview_sink,
1850:             runtime_handle,

## downgrader projection helpers 3620-3770
3620: ) {
3621:     let Some(projection) = with_downgrader_controller_mut(controller, |controller| {
3622:         project_downgrader_state(controller)
3623:     }) else {
3624:         return;
3625:     };
3626:     apply_downgrader_projection(window, projection);
3627: }
3628: 
3629: fn project_downgrader_state(controller: &DowngraderController) -> DowngraderUiProjection {
3630:     let status_rows = controller.status_rows();
3631:     let options = controller.options();
3632:     DowngraderUiProjection {
3633:         current_game_status_rows: format_downgrader_status_rows(
3634:             &status_rows,
3635:             DowngraderFileGroup::Game,
3636:         ),
3637:         current_creation_kit_status_rows: format_downgrader_status_rows(
3638:             &status_rows,
3639:             DowngraderFileGroup::CreationKit,
3640:         ),
3641:         selected_target: downgrader_target_ui_value(options.target).to_owned(),
3642:         keep_backups: options.keep_backups,
3643:         delete_patches: options.delete_deltas,
3644:         plan_rows: controller
3645:             .plan()
3646:             .map(|plan| plan.rows.iter().map(format_downgrader_plan_row).collect())
3647:             .unwrap_or_default(),
3648:         plan_visible: controller.plan().is_some(),
3649:         confirmation_state: if matches!(
3650:             controller.phase(),
3651:             app::downgrader_controller::DowngraderControllerPhase::PlanReady
3652:         ) {
3653:             "needs-confirmation".to_owned()
3654:         } else {
3655:             "idle".to_owned()
3656:         },
3657:         plan_confirmation_text: DOWNGRADER_PLAN_READY_MESSAGE.to_owned(),
3658:         log_rows: controller
3659:             .log_rows()
3660:             .iter()
3661:             .map(format_downgrader_log_row)
3662:             .collect(),
3663:         log_text: controller.status_text().to_owned(),
3664:         progress_percent: controller.progress().percent,
3665:         progress_text: controller.status_text().to_owned(),
3666:         patch_enabled: controller.patch_button_enabled(),
3667:         about_enabled: !matches!(
3668:             controller.phase(),
3669:             app::downgrader_controller::DowngraderControllerPhase::Running
3670:         ),
3671:         controls_enabled: !matches!(
3672:             controller.phase(),
3673:             app::downgrader_controller::DowngraderControllerPhase::LoadingStatus
3674:                 | app::downgrader_controller::DowngraderControllerPhase::Planning
3675:                 | app::downgrader_controller::DowngraderControllerPhase::Running
3676:         ),
3677:         close_blocked: !controller.close_enabled(),
3678:     }
3679: }
3680: 
3681: fn apply_downgrader_projection(window: &DowngraderWindow, projection: DowngraderUiProjection) {
3682:     window.set_current_game_status_rows(model_from_vec(projection.current_game_status_rows));
3683:     window.set_current_creation_kit_status_rows(model_from_vec(
3684:         projection.current_creation_kit_status_rows,
3685:     ));
3686:     window.set_selected_target(projection.selected_target.as_str().into());
3687:     window.set_keep_backups(projection.keep_backups);
3688:     window.set_delete_patches(projection.delete_patches);
3689:     window.set_plan_rows(model_from_vec(projection.plan_rows));
3690:     window.set_plan_visible(projection.plan_visible);
3691:     window.set_confirmation_state(projection.confirmation_state.as_str().into());
3692:     window.set_plan_confirmation_text(projection.plan_confirmation_text.as_str().into());
3693:     window.set_log_rows(model_from_vec(projection.log_rows));
3694:     window.set_log_text(projection.log_text.as_str().into());
3695:     window.set_progress_percent(projection.progress_percent);
3696:     window.set_progress_text(projection.progress_text.as_str().into());
3697:     window.set_patch_enabled(projection.patch_enabled);
3698:     window.set_about_enabled(projection.about_enabled);
3699:     window.set_controls_enabled(projection.controls_enabled);
3700:     window.set_close_blocked(projection.close_blocked);
3701: }
3702: 
3703: fn format_downgrader_status_rows(
3704:     rows: &[DowngraderStatusRow],
3705:     group: DowngraderFileGroup,
3706: ) -> Vec<DowngraderStatusUiRow> {
3707:     rows.iter()
3708:         .copied()
3709:         .filter(|row| row.group == group)
3710:         .map(|row| DowngraderStatusUiRow {
3711:             display_name: row.display_name.into(),
3712:             status: row.status_label().into(),
3713:             severity: downgrader_status_severity(row.status).into(),
3714:             detail: row.relative_path.into(),
3715:         })
3716:         .collect()
3717: }
3718: 
3719: fn format_downgrader_plan_row(
3720:     row: &services::downgrader::DowngraderPreviewPlanRow,
3721: ) -> DowngraderPlanUiRow {
3722:     let action = row.failure.as_deref().unwrap_or_else(|| {
3723:         row.steps
3724:             .first()
3725:             .map(|step| step.message.as_str())
3726:             .unwrap_or("No action.")
3727:     });
3728:     let detail = if row.failure.is_some() {
3729:         String::new()
3730:     } else {
3731:         row.steps
3732:             .iter()
3733:             .skip(1)
3734:             .map(|step| step.message.as_str())
3735:             .collect::<Vec<_>>()
3736:             .join(" ")
3737:     };
3738:     DowngraderPlanUiRow {
3739:         display_name: row.plan.display_name.into(),
3740:         action: action.into(),
3741:         detail: detail.as_str().into(),
3742:         severity: if row.failure.is_some() {
3743:             "error"
3744:         } else {
3745:             "neutral"
3746:         }
3747:         .into(),
3748:     }
3749: }
3750: 
3751: fn format_downgrader_log_row(row: &DowngraderExecutionLogRow) -> DowngraderLogUiRow {
3752:     DowngraderLogUiRow {
3753:         level: row.level.as_reference_str().into(),
3754:         message: row.message.as_str().into(),
3755:     }
3756: }
3757: 
3758: fn downgrader_target_ui_value(target: DowngraderTarget) -> &'static str {
3759:     match target {
3760:         DowngraderTarget::OldGen => "old_gen",
3761:         DowngraderTarget::NextGen => "next_gen",
3762:     }
3763: }
3764: 
3765: fn downgrader_status_severity(status: DowngraderInstallStatus) -> &'static str {
3766:     match status {
3767:         DowngraderInstallStatus::OldGen => "old-gen",
3768:         DowngraderInstallStatus::NextGen | DowngraderInstallStatus::NextGenAnniversary => {
3769:             "next-gen"
3770:         }

