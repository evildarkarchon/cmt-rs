269: fn main() -> Result<(), Box<dyn std::error::Error>> {
270:     let tokio_runtime = tokio::runtime::Builder::new_multi_thread()
271:         .enable_all()
272:         .thread_name("cmt-rs-worker")
273:         .build()?;
274:     let runtime_handle = tokio_runtime.handle().clone();
275:     let _runtime_guard = tokio_runtime.enter();
276: 
277:     let app = MainWindow::new()?;
278:     let settings_controller = Rc::new(RefCell::new(load_settings_controller()));
279:     let shared_settings_snapshot = Arc::new(Mutex::new(
280:         settings_controller.borrow().current_settings().clone(),
281:     ));
282:     let overview_controller = Arc::new(Mutex::new(OverviewController::new()));
283:     let f4se_controller = Arc::new(Mutex::new(F4seController::new()));
284:     let scanner_controller = Arc::new(Mutex::new(ScannerController::new(
285:         settings_controller
286:             .borrow()
287:             .current_scanner_settings()
288:             .clone(),
289:     )));
290:     let tools_controller = Arc::new(Mutex::new(ToolsController::new()));
291:     let about_controller = Arc::new(Mutex::new(AboutController::new()));
292:     let downgrader_controller = Arc::new(Mutex::new(DowngraderController::new()));
293:     let downgrader_window = DowngraderWindow::new()?;
294:     let worker_runtime = WorkerRuntime::new();
295: 
296:     app.set_update_source(settings_controller.borrow().visible_update_source().into());
297:     app.set_log_level(settings_controller.borrow().visible_log_level().into());
298:     apply_current_overview_snapshot(&app, &overview_controller);
299:     apply_current_f4se_snapshot(&app, &f4se_controller);
300:     apply_current_scanner_state(&app, &scanner_controller);
301:     apply_current_tools_state(&app, &tools_controller);
302:     apply_current_about_state(&app, &about_controller);
303:     apply_current_downgrader_state(&downgrader_window, &downgrader_controller);
304: 
305:     let overview_sink = bind_overview_worker_sink(&app, Arc::clone(&overview_controller));
306:     let f4se_sink = bind_f4se_worker_sink(&app, Arc::clone(&f4se_controller));
307:     let scanner_sink = bind_scanner_worker_sink(&app, Arc::clone(&scanner_controller));
308:     let tools_sink = bind_tools_worker_sink(&app, Arc::clone(&tools_controller));
309:     let about_sink = bind_about_worker_sink(&app, Arc::clone(&about_controller));
310:     let downgrader_sink = bind_downgrader_worker_sink(
311:         &app,
312:         &downgrader_window,
313:         Arc::clone(&downgrader_controller),
314:         Arc::clone(&overview_controller),
315:         Arc::clone(&shared_settings_snapshot),
316:         worker_runtime,
317:         overview_sink.clone(),
318:         runtime_handle.clone(),
319:     );
320:     bind_settings_callbacks(
321:         &app,
322:         Rc::clone(&settings_controller),
323:         Arc::clone(&shared_settings_snapshot),
324:     );
325:     bind_downgrader_callbacks(
326:         &downgrader_window,
327:         Arc::clone(&downgrader_controller),
328:         Rc::clone(&settings_controller),
329:         Arc::clone(&shared_settings_snapshot),
330:         worker_runtime,
331:         downgrader_sink.clone(),
332:     );
333:     bind_tools_callbacks(
334:         &app,
335:         &downgrader_window,
336:         Arc::clone(&tools_controller),
337:         Arc::clone(&downgrader_controller),
338:         Rc::clone(&settings_controller),
339:         worker_runtime,
340:         tools_sink.clone(),
341:         downgrader_sink.clone(),
342:     );
343:     bind_about_callbacks(
344:         &app,
345:         Arc::clone(&about_controller),
346:         worker_runtime,
347:         about_sink,
348:     );
349:     bind_f4se_callbacks(
350:         &app,
351:         Arc::clone(&f4se_controller),
352:         worker_runtime,
353:         f4se_sink,
354:     );
355:     bind_scanner_callbacks(
356:         &app,
357:         Arc::clone(&scanner_controller),
358:         Rc::clone(&settings_controller),
359:         worker_runtime,
360:         scanner_sink,
361:     );
362:     bind_overview_callbacks(
363:         &app,
364:         &downgrader_window,
365:         Arc::clone(&overview_controller),
366:         Arc::clone(&downgrader_controller),
367:         Rc::clone(&settings_controller),
368:         worker_runtime,
369:         overview_sink.clone(),
370:         downgrader_sink,
371:         runtime_handle.clone(),
372:     );
373: 
374:     request_overview_refresh(
375:         &app,
376:         &overview_controller,
377:         &settings_controller,
378:         worker_runtime,
379:         overview_sink,
380:         runtime_handle,
381:     );
382: 
383:     Ok(app.run()?)
384: }
