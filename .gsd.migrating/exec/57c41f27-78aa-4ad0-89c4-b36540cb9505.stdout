4245:    fn main_test_settings_controller(
4246:        name: &str,
4247:        settings: AppSettings,
4248:    ) -> (
4249:        Rc<RefCell<SettingsController<crate::platform::settings_store::StaticAssetResolver>>>,
4250:        PathBuf,
4251:    ) {
4252:        let root = unique_main_test_root(name);
4253:        std::fs::create_dir_all(&root).expect("settings test root should be created");
4254:        let settings_path = root.join("settings.json");
4255:        let store = SettingsStore::with_asset_resolver(
4256:            settings_path.clone(),
4257:            crate::platform::settings_store::StaticAssetResolver::new(Some("nexus")),
4258:        );
4259:        (
4260:            Rc::new(RefCell::new(SettingsController::from_settings(
4261:                store, settings,
4262:            ))),
4263:            settings_path,
4264:        )
4265:    }
4266:
4267:    fn unique_main_test_root(name: &str) -> PathBuf {
4268:        let unique = std::time::SystemTime::now()
4269:            .duration_since(std::time::UNIX_EPOCH)
4270:            .expect("test clock should be after Unix epoch")
4271:            .as_nanos();
4272:        std::env::temp_dir().join(format!("cmt-rs-main-{name}-{unique}"))
4273:    }
