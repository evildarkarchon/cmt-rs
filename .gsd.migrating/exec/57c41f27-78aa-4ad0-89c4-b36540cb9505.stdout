2369:fn emit_worker_event_or_log<S>(sink: &S, event: WorkerEvent)
2370:where
2371:    S: WorkerEventSink,
2372:{
2373:    let task_id = event.task.id.to_string();
2374:    let task_kind = event.task.kind.label();
2375:    let status = event.status.label();
2376:    if let Err(error) = sink.emit(event) {
2377:        tracing::warn!(
2378:            event = "overview-worker-handoff-failed",
2379:            task_id = %task_id,
2380:            task_kind,
2381:            status,
2382:            error = %error,
2383:            diagnostic = error.diagnostic.as_deref().unwrap_or(""),
2384:            "Overview worker event could not be handed to the UI"
2385:        );
2386:    }
2387:}
