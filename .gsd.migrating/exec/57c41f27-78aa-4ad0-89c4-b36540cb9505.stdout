1805:                details_text,
1806:            })
1807:    })
1808:    .flatten()
1809:}
1810:
1811:fn scanner_action_task(action: ScannerActionKind, scan_id: Option<u64>) -> WorkerTask {
1812:    let scan_label = scan_id
1813:        .map(|scan_id| scan_id.to_string())
1814:        .unwrap_or_else(|| "none".to_owned());
1815:    WorkerTask::new(
1816:        format!(
1817:            "{SCANNER_ACTION_TASK_PREFIX}{scan_label}:{}",
1818:            action.as_id()
1819:        ),
1820:        WorkerTaskKind::DesktopAction,
1821:    )
1822:    .with_label(action.as_id())
1823:}
1824:
1825:fn scanner_action_from_task_id(
1826:    task_id: &workers::WorkerTaskId,
1827:) -> Option<(Option<u64>, ScannerActionKind)> {
1828:    let rest = task_id.as_str().strip_prefix(SCANNER_ACTION_TASK_PREFIX)?;
1829:    let (scan_id, action_id) = rest.split_once(':')?;
1830:    let scan_id = if scan_id == "none" {
1831:        None
1832:    } else {
1833:        Some(scan_id.parse::<u64>().ok()?)
1834:    };
1835:    Some((scan_id, ScannerActionKind::from_id(action_id)?))
1836:}
1837:
1838:fn execute_scanner_action_payload(execution: ScannerActionExecution) -> BlockingWorkerResult {
1839:    let feedback = execute_scanner_action_with_adapters(
1840:        execution,
1841:        RealDesktopActions::new(),
1842:        RealClipboardActions::new(),
1843:    );
1844:    Ok(WorkerTaskOutcome::Completed(
1845:        scanner_action_completed_payload(feedback),
1846:    ))
1847:}
1848:
1849:fn execute_scanner_action_with_adapters<D, C>(
1850:    execution: ScannerActionExecution,
1851:    desktop: D,
1852:    clipboard: C,
1853:) -> ScannerActionFeedback
1854:where
1855:    D: DesktopActions,
1856:    C: ClipboardActions,
1857:{
1858:    let scan_id = execution.scan_id;
1859:    let action = execution.descriptor.kind;
1860:    match (action, execution.descriptor.target) {
1861:        (ScannerActionKind::CopyDetails, ScannerActionTarget::DetailsText) => {
1862:            let Some(details_text) = execution.details_text.filter(|text| !text.is_empty()) else {
1863:                return ScannerActionFeedback::failed(
1864:                    scan_id,
1865:                    action,
1866:                    "Scanner details are not available to copy.",
1867:                );
1868:            };
1869:            scanner_feedback_from_clipboard_result(
1870:                scan_id,
1871:                action,
1872:                clipboard.copy_text(&details_text),
1873:            )
1874:        }
1875:        (ScannerActionKind::OpenLocation, ScannerActionTarget::Path(path)) => {
1876:            scanner_feedback_from_desktop_result(scan_id, action, desktop.open_path(&path))
1877:        }
1878:        (ScannerActionKind::OpenSolutionUrl, ScannerActionTarget::Url(url)) => {
1879:            scanner_feedback_from_desktop_result(scan_id, action, desktop.open_url(&url))
1880:        }
1881:        (ScannerActionKind::CopySolutionUrl, ScannerActionTarget::Url(url)) => {
1882:            scanner_feedback_from_clipboard_result(scan_id, action, clipboard.copy_text(&url))
1883:        }
1884:        _ => ScannerActionFeedback::failed(scan_id, action, SCANNER_ACTION_UNAVAILABLE_MESSAGE),
1885:    }
1886:}
