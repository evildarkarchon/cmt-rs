4198:    fn s07_scanner_runtime_wiring_action_worker_failure_event_maps_to_safe_feedback() {
4199:        let mut controller = ScannerController::default();
4200:        let request = controller.request_scan().expect("scan should start");
4201:        controller.scan_completed(
4202:            request.scan_id,
4203:            ScannerScanSnapshot::empty(request.scan_id, "Scanner scan complete."),
4204:        );
4205:        let task = scanner_action_task(ScannerActionKind::OpenLocation, Some(request.scan_id));
4206:        assert_eq!(
4207:            scanner_action_from_task_id(&task.id),
4208:            Some((Some(request.scan_id), ScannerActionKind::OpenLocation))
4209:        );
4210:
4211:        let result = handle_scanner_worker_event(
4212:            &mut controller,
4213:            WorkerEvent::failed(
4214:                task,
4215:                WorkerFailure::new("Path open failed.").with_diagnostic("raw worker failure"),
4216:            ),
4217:        );
4218:
4219:        assert_eq!(result, ScannerTransitionResult::Applied);
4220:        let feedback = controller
4221:            .last_action_feedback()
4222:            .expect("failed action feedback should be visible");
4223:        assert_eq!(feedback.safe_message(), "Path open failed.");
4224:        assert_eq!(feedback.diagnostic.as_deref(), Some("raw worker failure"));
4225:        let projection = project_scanner_state(&controller);
4226:        assert_eq!(projection.action_feedback, "Path open failed.");
4227:        assert!(!projection.action_feedback.contains("raw worker"));
4228:    }
