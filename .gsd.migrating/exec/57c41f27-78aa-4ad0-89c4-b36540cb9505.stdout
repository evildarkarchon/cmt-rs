2321:        ScannerActionFeedback::failed(scan_id, action, failure.safe_message.clone())
2322:            .with_diagnostic(
2323:                failure
2324:                    .diagnostic
2325:                    .clone()
2326:                    .unwrap_or_else(|| "scanner action worker failed".to_owned()),
2327:            ),
2328:    )
2329:}
