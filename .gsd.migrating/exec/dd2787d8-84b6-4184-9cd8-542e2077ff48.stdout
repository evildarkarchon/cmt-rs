1496: fn with_overview_controller_mut<T>(
1497:     controller: &Arc<Mutex<OverviewController>>,
1498:     action: impl FnOnce(&mut OverviewController) -> T,
1499: ) -> Option<T> {
1500:     match controller.lock() {
1501:         Ok(mut controller) => Some(action(&mut controller)),
1502:         Err(error) => {
1503:             tracing::error!(
1504:                 event = "overview-controller-lock-poisoned",
1505:                 diagnostic = %error,
1506:                 "Overview controller state is unavailable"
1507:             );
1508:             None
1509:         }
1510:     }
1511: }
1512: 
