1733: fn apply_overview_snapshot(app: &MainWindow, snapshot: &OverviewSnapshot) {
1734:     app.set_overview_refresh_message(refresh_message(&snapshot.refresh).into());
1735:     app.set_overview_refresh_busy(snapshot.refresh.is_busy());
1736:     app.set_overview_top_rows(model_from_vec(format_top_rows(snapshot)));
1737:     app.set_overview_binary_rows(model_from_vec(format_binary_rows(snapshot)));
1738:     app.set_overview_archive_rows(model_from_vec(format_count_panel_rows(
1739:         &snapshot.archives.rows,
1740:     )));
1741:     app.set_overview_module_rows(model_from_vec(format_count_panel_rows(
1742:         &snapshot.modules.rows,
1743:     )));
1744:     app.set_overview_problems_summary(format_problem_summary(snapshot).into());
1745:     app.set_overview_problem_rows(model_from_vec(format_problem_rows(snapshot)));
1746:     app.set_overview_game_path_enabled(matches!(
1747:         snapshot.top.game_path,
1748:         domain::overview::OverviewGamePathStatus::Found(_)
1749:     ));
1750:     app.set_overview_downgrade_label(
1751:         deferred_action_label(
1752:             &snapshot.binaries.actions,
1753:             OverviewDeferredActionKind::OpenDowngradeManager,
1754:             ACTION_DOWNGRADE_MANAGER_LABEL,
1755:         )
1756:         .into(),
1757:     );
1758:     app.set_overview_downgrade_enabled(false);
1759:     app.set_overview_downgrade_status(
1760:         deferred_action_status(
1761:             &snapshot.binaries.actions,
1762:             OverviewDeferredActionKind::OpenDowngradeManager,
1763:             "Downgrade Manager",
1764:         )
1765:         .into(),
1766:     );
1767:     app.set_overview_archive_patcher_label(
1768:         deferred_action_label(
1769:             &snapshot.archives.actions,
1770:             OverviewDeferredActionKind::OpenArchivePatcher,
1771:             ACTION_ARCHIVE_PATCHER_LABEL,
1772:         )
1773:         .into(),
1774:     );
1775:     app.set_overview_archive_patcher_enabled(false);
1776:     app.set_overview_archive_patcher_status(
1777:         deferred_action_status(
1778:             &snapshot.archives.actions,
1779:             OverviewDeferredActionKind::OpenArchivePatcher,
1780:             "Archive Patcher",
1781:         )
1782:         .into(),
1783:     );
1784:     app.set_overview_last_action_error(
1785:         snapshot
1786:             .last_action_error
1787:             .as_ref()
1788:             .map(|error| error.summary.as_str())
1789:             .unwrap_or("")
1790:             .into(),
1791:     );
1792:     apply_update_banner(app, &snapshot.update_banner);
1793: }
