1: extern crate bindgen;
2: extern crate cc;
3: 
4: use std::env;
5: use std::process::Command;
6: 
7: use rand::Rng;
8: use std::fs::{remove_file, File};
9: use std::io::Write;
10: use std::path::PathBuf;
11: 
12: fn add_def(v: &mut Vec<(String, String)>, key: &str, val: &str) {
13:     v.push((key.to_owned(), val.to_owned()));
14: }
15: 
16: fn main() {
17:     let mut defines = Vec::new();
18:     for i in &[
19:         "size_t",
20:         "unsigned int",
21:         "unsigned long",
22:         "unsigned long long",
23:     ] {
24:         let def_name = format!("SIZEOF_{}", i.to_uppercase().replace(" ", "_"));
25:         defines.push((def_name, check_native_size(i)));
26:     }
27:     add_def(&mut defines, "SECONDARY_DJW", "1");
28:     add_def(&mut defines, "SECONDARY_FGK", "1");
29:     add_def(&mut defines, "EXTERNAL_COMPRESSION", "0");
30:     add_def(&mut defines, "XD3_USE_LARGEFILE64", "1");
31: 
32:     #[cfg(windows)]
33:     add_def(&mut defines, "XD3_WIN32", "1");
34:     add_def(&mut defines, "SHELL_TESTS", "0");
35: 
36:     {
37:         let mut builder = cc::Build::new();
38:         builder.include("xdelta3/xdelta3");
39:         for (key, val) in &defines {
40:             builder.define(&key, Some(val.as_str()));
41:         }
42: 
43:         builder
44:             .file("xdelta3/xdelta3/xdelta3.c")
45:             .warnings(false)
46:             .compile("xdelta3");
47:     }
48: 
49:     {
50:         let mut builder = bindgen::Builder::default();
51: 
52:         for (key, val) in &defines {
53:             builder = builder.clang_arg(format!("-D{}={}", key, val));
54:         }
55:         let bindings = builder
56:             .header("xdelta3/xdelta3/xdelta3.h")
57:             .parse_callbacks(Box::new(bindgen::CargoCallbacks))
58:             .whitelist_function("xd3_.*")
59:             .generate()
60:             .expect("Unable to generate bindings");
61: 
62:         // Write the bindings to the $OUT_DIR/bindings.rs file.
63:         let out_path = PathBuf::from(env::var("OUT_DIR").unwrap());
64:         bindings
65:             .write_to_file(out_path.join("bindings.rs"))
66:             .expect("Couldn't write bindings!");
67:     }
68: }
69: 
70: fn check_native_size(name: &str) -> String {
71:     let builder = cc::Build::new();
72:     let out_dir = env::var("OUT_DIR").unwrap();
73:     let compiler = builder.get_compiler();
74:     let mut compile = Command::new(compiler.path().as_os_str());
75:     let test_code = format!("#include <stdint.h>\n#include <stdio.h>\nint main() {{printf(\"%lu\", sizeof({})); return 0;}}\n", name);
76:     // didn't use tempfile since tempfile was having issues on Windows
77:     let mut rng = rand::thread_rng();
78:     let test_binary_fn = format!("{}/test-{}", out_dir, rng.gen::<i32>());
79: 
80:     #[cfg(windows)]
