696: fn build_f4se_scan_snapshot(scan_id: u64) -> F4seScanSnapshot {
697:     let span = tracing::info_span!("f4se_scan_worker", scan_id);
698:     let _guard = span.enter();
699:     tracing::info!(
700:         event = "s06-f4se-scan-started",
701:         scan_id,
702:         "F4SE scan worker started"
703:     );
704: 
705:     let filesystem = RealFilesystem::new();
706:     let registry = RealRegistry::new();
707:     let process = RealProcessInspector::new();
708:     let current_working_directory = current_working_directory();
709:     let local_appdata = std::env::var_os("LOCALAPPDATA").map(PathBuf::from);
710: 
711:     let mut discovery_request = DiscoveryRequest::new(current_working_directory);
712:     discovery_request = discovery_request.with_current_process_id(std::process::id());
713:     if let Some(path) = local_appdata.clone() {
714:         discovery_request = discovery_request.with_local_appdata(path);
715:     }
716: 
717:     let discovery =
718:         DiscoveryService::new(&filesystem, &registry, &process).discover(&discovery_request);
719:     if let Err(error) = &discovery.game {
720:         tracing::warn!(
721:             event = "s06-f4se-discovery-failure",
722:             scan_id,
723:             safe_message = %error.user_message(),
724:             "F4SE discovery did not find a usable Fallout 4 installation"
725:         );
726:     }
727:     if let Err(error) = &discovery.mod_manager {
728:         tracing::warn!(
729:             event = "s06-f4se-manager-discovery-failure",
730:             scan_id,
731:             safe_message = %error.user_message(),
732:             "F4SE mod-manager discovery failed safely"
733:         );
734:     }
735: 
736:     let mut collection_environment = OverviewCollectionEnvironment::new();
737:     if let Some(path) = local_appdata {
738:         collection_environment = collection_environment.with_local_appdata(path);
739:     }
740: 
741:     let collected = match &discovery.game {
742:         Ok(installation) => {
743:             let collector = OverviewCollector::new(&filesystem, &process);
744:             collector.collect(OverviewCollectionRequest::new(
745:                 installation,
746:                 &collection_environment,
747:             ))
748:         }
749:         Err(_) => OverviewCollectedFacts::default(),
750:     };
751:     let current_game = f4se_current_game_from_overview_facts(&collected);
752:     tracing::info!(
753:         event = "s06-f4se-current-game-classified",
754:         scan_id,
755:         current_game = ?current_game,
756:         binaries = collected.binaries.len(),
757:         "F4SE current-game target classified from Overview Fallout4.exe facts"
758:     );

