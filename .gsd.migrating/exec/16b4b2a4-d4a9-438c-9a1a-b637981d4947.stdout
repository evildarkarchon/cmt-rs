1658: fn project_tools_state(state: &ToolsState) -> ToolsUiProjection {
1659:     ToolsUiProjection {
1660:         last_action_error: state
1661:             .last_safe_error
1662:             .as_ref()
1663:             .map(|error| error.summary.clone())
1664:             .unwrap_or_default(),
1665:         disabled_utility_status: state
1666:             .disabled_utility_status
1667:             .clone()
1668:             .unwrap_or_else(|| TOOLS_DEFAULT_DISABLED_UTILITY_STATUS.to_owned()),
1669:     }
1670: }
1671: 
1672: fn project_about_state(state: &AboutState) -> AboutUiProjection {
1673:     let nexus = about_copy_projection(state, AboutLinkId::Nexus);
1674:     let discord = about_copy_projection(state, AboutLinkId::Discord);
1675:     let github = about_copy_projection(state, AboutLinkId::Github);
1676: 
1677:     AboutUiProjection {
1678:         last_action_error: state
1679:             .last_safe_error
1680:             .as_ref()
1681:             .map(|error| error.summary.clone())
1682:             .unwrap_or_default(),
1683:         nexus_copy_label: nexus.0,
1684:         nexus_copy_enabled: nexus.1,
1685:         discord_copy_label: discord.0,
1686:         discord_copy_enabled: discord.1,
1687:         github_copy_label: github.0,
1688:         github_copy_enabled: github.1,
1689:     }
1690: }
1691: 
1692: fn about_copy_projection(state: &AboutState, link_id: AboutLinkId) -> (String, bool) {
1693:     if let Some(button) = state
1694:         .copy_buttons
1695:         .iter()
1696:         .find(|button| button.link_id == link_id)
1697:     {
1698:         return (button.label.clone(), button.enabled);
1699:     }
1700: 
1701:     let fallback_label = ABOUT_LINKS
1702:         .iter()
1703:         .find(|link| link.id == link_id)
1704:         .map(|link| link.copy_button_label)
1705:         .unwrap_or_default();
1706:     (fallback_label.to_owned(), true)
1707: }
1708: 
1709: fn apply_tools_projection(app: &MainWindow, projection: &ToolsUiProjection) {
1710:     app.set_tools_last_action_error(projection.last_action_error.as_str().into());
1711:     app.set_tools_disabled_utility_status(projection.disabled_utility_status.as_str().into());
1712: }
1713: 
1714: fn apply_about_projection(app: &MainWindow, projection: &AboutUiProjection) {
1715:     app.set_about_last_action_error(projection.last_action_error.as_str().into());
1716:     app.set_about_nexus_copy_label(projection.nexus_copy_label.as_str().into());
1717:     app.set_about_nexus_copy_enabled(projection.nexus_copy_enabled);
1718:     app.set_about_discord_copy_label(projection.discord_copy_label.as_str().into());
1719:     app.set_about_discord_copy_enabled(projection.discord_copy_enabled);

