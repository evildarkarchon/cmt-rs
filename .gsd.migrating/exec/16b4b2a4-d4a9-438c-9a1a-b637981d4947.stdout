1438: fn tools_worker_failure_feedback_from_event(event: &WorkerEvent) -> Option<ToolsActionFeedback> {
1439:     let WorkerPayload::Error(failure) = &event.payload else {
1440:         return None;
1441:     };
1442:     let action_id = tools_action_id_from_task(&event.task)?;
1443: 
1444:     Some(ToolsActionFeedback::rejected(
1445:         action_id,
1446:         tools_action_for_id(action_id).ok(),
1447:         ActionRejectionKind::WorkerUnavailable,
1448:         failure.safe_message.clone(),
1449:         failure.diagnostic.clone(),
1450:     ))
1451: }
1452: 
