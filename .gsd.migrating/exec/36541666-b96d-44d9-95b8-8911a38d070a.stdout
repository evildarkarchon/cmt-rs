675:     /// Creates an archive panel by counting supplied archive records.
676:     pub fn from_records(records: &[ArchiveRecord]) -> Self {
677:         let mut counts = ArchivePanelCounts::default();
678: 
679:         for record in records
680:             .iter()
681:             .filter(|record| record.enabled || !record.readable)
682:         {
683:             let invalid_or_unreadable = !record.readable
684:                 || matches!(record.format, ArchiveFormat::Unknown(_))
685:                 || matches!(record.version, ArchiveVersion::Unknown(_));
686:             if invalid_or_unreadable {
687:                 counts.unreadable += 1;
688:                 continue;
689:             }
690: 
691:             match record.format {
692:                 ArchiveFormat::General => counts.general += 1,
693:                 ArchiveFormat::DirectX10 => counts.texture += 1,
694:                 ArchiveFormat::Unknown(_) => {}
