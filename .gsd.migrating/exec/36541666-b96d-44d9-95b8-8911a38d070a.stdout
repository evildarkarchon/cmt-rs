1346:     /// Creates a snapshot from typed discovery results without reading the host OS.
1347:     pub fn from_discovery_parts(
1348:         installation: Option<Fallout4Installation>,
1349:         mod_manager: Option<DiscoveredModManager>,
1350:         system_metadata: Option<SystemMetadata>,
1351:         update_source: UpdateSource,
1352:     ) -> Self {
1353:         let mut snapshot = Self {
1354:             update_banner: UpdateBannerState::from_update_source(update_source),
1355:             ..Self::default()
1356:         };
1357: 
1358:         snapshot.top.system_metadata = system_metadata;
1359: 
1360:         if let Some(manager) = mod_manager {
1361:             snapshot.top.mod_manager = OverviewModManagerStatus::detected(manager);
1362:         } else {
1363:             snapshot.problems.push(OverviewProblem::pathless(
1364:                 OverviewProblemSource::TopStatus,
1365:                 TOP_ROW_MOD_MANAGER_LABEL,
1366:                 OverviewProblemType::NoModManager,

