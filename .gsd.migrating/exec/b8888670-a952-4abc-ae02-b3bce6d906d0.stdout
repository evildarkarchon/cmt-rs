1120: impl OverviewProblemType {
1121:     /// Returns the user-facing problem label.
1122:     pub fn label(&self) -> &str {
1123:         match self {
1124:             Self::InvalidArchive => "Invalid Archive",
1125:             Self::InvalidModule => "Invalid Module",
1126:             Self::FileNotFound => "File Not Found",
1127:             Self::WrongVersion => "Wrong Version",
1128:             Self::LimitExceeded => "Limit Exceeded",
1129:             Self::NoModManager => "No Mod Manager",
1130:             Self::UnknownGameVersion => "Unknown Game Version",
1131:             Self::Custom(label) => label.as_str(),
1132:         }
1133:     }
1134: }
