1695:     #[test]
1696:     fn problem_feed_records_carry_scanner_ready_overview_domain_fields() {
1697:         let path_problem = OverviewProblem::with_path(
1698:             OverviewProblemSource::Archives,
1699:             "C:/Games/Fallout 4/Data/Broken.ba2",
1700:             Some(PathBuf::from("Broken.ba2")),
1701:             OverviewProblemType::InvalidArchive,
1702:             "Archive is either corrupt or not in Bethesda Archive 2 format.",
1703:             None::<String>,
1704:         )
1705:         .with_mod_name(Some("<Unmanaged>".to_owned()))
1706:         .with_details(vec![OverviewProblemDetail::new("Version", "99")]);
1707: 
1708:         assert_eq!(path_problem.source, OverviewProblemSource::Archives);
1709:         assert_eq!(
1710:             path_problem.path.as_deref(),
1711:             Some(Path::new("C:/Games/Fallout 4/Data/Broken.ba2"))
1712:         );
1713:         assert_eq!(
1714:             path_problem.relative_path.as_deref(),
1715:             Some(Path::new("Broken.ba2"))
1716:         );
1717:         assert_eq!(path_problem.problem.label(), "Invalid Archive");
1718:         assert_eq!(
1719:             path_problem.summary,
1720:             "Archive is either corrupt or not in Bethesda Archive 2 format."
1721:         );
1722:         assert_eq!(path_problem.solution, None);
1723:         assert_eq!(path_problem.details[0].value, "99");
1724: 
1725:         let pathless = OverviewProblem::pathless(
1726:             OverviewProblemSource::CountLimit,
1727:             "300 General Archives",
1728:             OverviewProblemType::LimitExceeded,
1729:             "You have 300 General Archives enabled. The limit is 256.",
1730:             Some("Archives can be unpacked or merged to reduce your total.".to_owned()),
1731:         )
1732:         .with_links(vec![OverviewProblemLink::new(
1733:             Some("Unpackrr".to_owned()),
1734:             "https://www.nexusmods.com/fallout4/mods/82082",
1735:         )])
1736:         .with_details(vec![OverviewProblemDetail::new("Limit", "256")]);
1737: 
1738:         assert_eq!(pathless.path, None);
1739:         assert_eq!(pathless.display_path, "300 General Archives");
1740:         assert_eq!(pathless.problem.label(), "Limit Exceeded");
1741:         assert_eq!(
1742:             pathless.solution.as_deref(),
1743:             Some("Archives can be unpacked or merged to reduce your total.")
1744:         );
1745:         assert_eq!(pathless.links[0].label.as_deref(), Some("Unpackrr"));
1746:         assert_eq!(pathless.details[0].name, "Limit");
1747:     }
1748: 
1749:     #[test]
1750:     fn archive_and_module_record_counts_keep_reference_order_and_severity() {
1751:         let archives = ArchivePanelSummary::from_counts(ArchivePanelCounts {
1752:             general: 243,
1753:             texture: 256,
1754:             unreadable: 1,
1755:             old_gen_version: 2,
1756:             next_gen_version: 3,
1757:         });
1758:         assert_eq!(row_labels(&archives.rows), ARCHIVE_COUNT_LABELS);
1759:         assert_eq!(archives.rows[0].severity, StatusSeverity::Warning);
1760:         assert_eq!(archives.rows[1].severity, StatusSeverity::Error);
1761:         assert_eq!(archives.rows[3].severity, StatusSeverity::Error);
1762:         assert_eq!(archives.rows[4].value, 2);
1763:         assert_eq!(archives.rows[5].value, 3);
1764: 
