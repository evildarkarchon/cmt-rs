1294: /// Complete, UI-independent Overview snapshot.
1295: #[derive(Debug, Default, Clone, PartialEq, Eq)]
1296: pub struct OverviewSnapshot {
1297:     /// Last refresh lifecycle state.
1298:     pub refresh: OverviewRefreshState,
1299:     /// Top status rows derived from discovery and system metadata.
1300:     pub top: OverviewTopStatus,
1301:     /// Binary panel state.
1302:     pub binaries: BinaryPanelSummary,
1303:     /// Archive panel state.
1304:     pub archives: ArchivePanelSummary,
1305:     /// Module panel state.
1306:     pub modules: ModulePanelSummary,
1307:     /// Update banner state.
1308:     pub update_banner: UpdateBannerState,
1309:     /// Scanner-ready problem records.
1310:     pub problems: Vec<OverviewProblem>,
1311:     /// Last safe action error, such as a desktop-open failure.
1312:     pub last_action_error: Option<OverviewActionError>,
1313: }
1314: 
1315: impl OverviewSnapshot {
1316:     /// Creates an empty snapshot with labels/actions present and no OS access.
1317:     pub fn empty() -> Self {
1318:         Self::default()
1319:     }
1320: 
1321:     /// Creates a loading snapshot.
1322:     pub fn loading(message: impl Into<String>) -> Self {
1323:         Self {
1324:             refresh: OverviewRefreshState::loading(message),
1325:             ..Self::default()
1326:         }
1327:     }
1328: 
1329:     /// Creates a partial snapshot from already-safe data.
1330:     pub fn partial(message: impl Into<String>, problems: Vec<OverviewProblem>) -> Self {
1331:         Self {
1332:             refresh: OverviewRefreshState::partial(message),
1333:             problems,
1334:             ..Self::default()
1335:         }
1336:     }
1337: 
1338:     /// Creates an error snapshot from a safe message.
1339:     pub fn error(message: impl Into<String>) -> Self {
1340:         Self {
1341:             refresh: OverviewRefreshState::error(message),
1342:             ..Self::default()
1343:         }
1344:     }
1345: 
1346:     /// Creates a snapshot from typed discovery results without reading the host OS.
1347:     pub fn from_discovery_parts(
1348:         installation: Option<Fallout4Installation>,
1349:         mod_manager: Option<DiscoveredModManager>,
1350:         system_metadata: Option<SystemMetadata>,
1351:         update_source: UpdateSource,
1352:     ) -> Self {
1353:         let mut snapshot = Self {
1354:             update_banner: UpdateBannerState::from_update_source(update_source),
1355:             ..Self::default()
1356:         };
1357: 
1358:         snapshot.top.system_metadata = system_metadata;
1359: 
1360:         if let Some(manager) = mod_manager {
1361:             snapshot.top.mod_manager = OverviewModManagerStatus::detected(manager);
1362:         } else {
1363:             snapshot.problems.push(OverviewProblem::pathless(
1364:                 OverviewProblemSource::TopStatus,
1365:                 TOP_ROW_MOD_MANAGER_LABEL,
1366:                 OverviewProblemType::NoModManager,
1367:                 "No Mod Manager Detected",
1368:                 Some("Your mod manager must launch the app to be detected.".to_owned()),
1369:             ));
1370:         }
1371: 
1372:         if let Some(installation) = installation {
1373:             snapshot.top.game_path = OverviewGamePathStatus::found(installation.game_path.clone());
1374:             snapshot.top.version = installation.install_type;
1375:             snapshot.archives = ArchivePanelSummary::from_records(&installation.archives);

