61: class F4SEPluginVersionData(ctypes.Structure):
62: 	_fields_: ClassVar[Fields] = [
63: 		("dataVersion", ctypes.c_uint32),
64: 		("pluginVersion", ctypes.c_uint32),
65: 		("name", ctypes.c_char * 256),
66: 		("author", ctypes.c_char * 256),
67: 		("addressIndependence", ctypes.c_uint32),
68: 		("structureIndependence", ctypes.c_uint32),
69: 		("compatibleVersions", ctypes.c_uint32 * 16),
70: 		("seVersionRequired", ctypes.c_uint32),
71: 		("reservedNonBreaking", ctypes.c_uint32),
72: 		("reservedBreaking", ctypes.c_uint32),
73: 		("reserved", ctypes.c_uint8 * 512),
74: 	]
