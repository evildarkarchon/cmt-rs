161: def get_environment_path(location: CSIDL) -> Path:
162: 	buf = create_unicode_buffer(wintypes.MAX_PATH)
163: 	windll.shell32.SHGetFolderPathW(None, location, None, 0, buf)
164: 	path = Path(buf.value)
165: 	if not is_dir(path):
166: 		msg = f"Folder does not exist:\n{path}"
167: 		raise FileNotFoundError(msg)
168: 	return path
