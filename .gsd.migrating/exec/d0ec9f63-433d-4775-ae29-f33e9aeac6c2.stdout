175: def find_mod_manager() -> ModManagerInfo | None:
176: 	pid = os.getppid()
177: 	proc: Process | None = Process(pid)
178: 
179: 	managers = {"ModOrganizer.exe", "Vortex.exe"}
180: 	manager = None
181: 
182: 	for _ in range(8):
183: 		if proc is None:
184: 			break
185: 
186: 		with proc.oneshot():
187: 			if proc.name() in managers:
188: 				manager_path = Path(proc.exe())
189: 				manager = "Mod Organizer" if proc.name() == "ModOrganizer.exe" else "Vortex"
190: 				ver = get_file_version(manager_path)
191: 				manager_version = Version(".".join(str(n) for n in ver[:3])) if ver else Version("0.0.0")
192: 				return ModManagerInfo(manager, manager_path, manager_version)
193: 			proc = proc.parent()
194: 	return None
195: 
196: 
197: def get_asset_path(relative_path: str) -> Path:
198: 	# PyInstaller EXEs extract to a temp folder and store the path in sys._MEIPASS
199: 	base_path = Path(str(getattr(sys, "_MEIPASS", False) or "."))
200: 	return base_path / "assets" / relative_path
201: 
202: 
203: def block_text_input(event: Event[Text]) -> str | None:
204: 	# Block all input except CTRL+A / CTRL+C
205: 	if event.state == KEY_CTRL and event.keysym in "AC":
206: 		return None
207: 	return "break"
208: 
209: 
210: def get_file_version(path: Path) -> tuple[int, int, int, int] | None:
211: 	try:
212: 		info = win32api.GetFileVersionInfo(str(path), "\\")
213: 	except:
214: 		return None
215: 	ms = info["FileVersionMS"]
216: 	ls = info["FileVersionLS"]
217: 	return (
218: 		win32api.HIWORD(ms),
219: 		win32api.LOWORD(ms),
220: 		win32api.HIWORD(ls),
221: 		win32api.LOWORD(ls),
222: 	)
223: 
224: 
225: def get_crc32(file_path: Path, chunk_size: int = 65536, max_chunks: int | None = None, *, skip_ba2_header: bool = False) -> str:
226: 	with file_path.open("rb") as f:
227: 		checksum = 0
228: 		chunks = 0
229: 		if skip_ba2_header:
230: 			f.seek(12)
231: 		while chunk := f.read(chunk_size):
232: 			checksum = zlib.crc32(chunk, checksum)
233: 			if max_chunks is not None:
234: 				chunks += 1
235: 				if chunks >= max_chunks:
236: 					break
237: 	return f"{checksum:08X}"
238: 
239: 
240: def parse_dll(file_path: Path) -> DLLInfo:
241: 	dll = WinDLL(str(file_path), winmode=DONT_RESOLVE_DLL_REFERENCES)
242: 	dll_info: DLLInfo = {
243: 		"IsF4SE": hasattr(dll, "F4SEPlugin_Load") or hasattr(dll, "F4SEPlugin_Preload"),
244: 		"SupportsOG": hasattr(dll, "F4SEPlugin_Query"),
245: 		"SupportsNGAE": hasattr(dll, "F4SEPlugin_Version"),
246: 		"SupportsNG": None,
247: 		"SupportsAE": None,
248: 	}
249: 
250: 	if dll_info["SupportsNGAE"]:
251: 		sym = ctypes.cast(
252: 			dll.F4SEPlugin_Version,
253: 			POINTER(F4SEPluginVersionData),
254: 		)
255: 		v = sym.contents
256: 		if 0x010A3D40 in v.compatibleVersions or 0x010A3D80 in v.compatibleVersions:
257: 			dll_info["SupportsNG"] = True
258: 
259: 		if any(n > 0x010B0890 for n in v.compatibleVersions):
260: 			dll_info["SupportsAE"] = True
261: 
262: 	return dll_info
263: 
264: 
265: def ver_to_str(version: str | tuple[int, int, int, int]) -> str:
266: 	if isinstance(version, str):
267: 		return version
268: 
269: 	return ".".join(map(str, version))
270: 
271: 
272: def get_registry_value(key: int, subkey: str, value_name: str) -> str | None:
273: 	try:
274: 		with winreg.OpenKey(key, subkey) as reg_handle:
275: 			value, value_type = winreg.QueryValueEx(reg_handle, value_name)
276: 
277: 		if value and value_type == winreg.REG_SZ and isinstance(value, str):
278: 			return value
279: 
