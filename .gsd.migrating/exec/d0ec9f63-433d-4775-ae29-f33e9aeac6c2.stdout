147: def read_text_encoded(file_path: Path) -> tuple[str, str]:
148: 	file_bytes = file_path.read_bytes()
149: 	encoding = chardet.detect(file_bytes)["encoding"] or "utf-8"
150: 	return file_bytes.decode(encoding), encoding
151: 
