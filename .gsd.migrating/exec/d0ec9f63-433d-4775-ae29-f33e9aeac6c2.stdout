76: def rglob(path: Path, ext: str) -> Generator[Path]:
77: 	if not win11_24h2:
78: 		yield from path.rglob(f"*.{ext}")
79: 		return
80: 
81: 	ext = ext.lower()
82: 	for root, _, files in path.walk():
83: 		for file in files:
84: 			if file.lower().endswith(f"*.{ext}"):
85: 				yield root / file
86: 
87: 
88: def is_file(path: Path) -> bool:
89: 	if not win11_24h2:
90: 		return path.is_file()
91: 
92: 	try:
93: 		with path.open(encoding="utf-8"):
94: 			pass
95: 	except FileNotFoundError:
96: 		return False
97: 	except PermissionError:
98: 		# Probably a folder
99: 		try:
100: 			_ = next(path.iterdir(), None)
101: 		except NotADirectoryError:
102: 			# Was a file with actual PermissionError
103: 			return True
104: 		except OSError:
105: 			pass
106: 		return False
107: 	return True
108: 
109: 
110: def is_dir(path: Path) -> bool:
111: 	if not win11_24h2:
112: 		return path.is_dir()
113: 
114: 	try:
115: 		_ = next(path.iterdir(), None)
116: 	except (NotADirectoryError, FileNotFoundError):
117: 		return False
118: 	return True
119: 
120: 
121: def exists(path: Path) -> bool:
122: 	if not win11_24h2:
123: 		return path.exists()
124: 
125: 	# Files
126: 	try:
127: 		with path.open(encoding="utf-8"):
128: 			return True
129: 	except FileNotFoundError:
130: 		return False
131: 	except PermissionError:
132: 		# Probably a folder, check below
133: 		pass
134: 
135: 	# Folders
136: 	try:
137: 		_ = next(path.iterdir(), None)
138: 	except (PermissionError, NotADirectoryError):
139: 		# PermissionError: Actual folder but no permission
140: 		# NotADirectoryError: Was a file with actual PermissionError
141: 		pass
142: 	except OSError:
143: 		return False
144: 	return True
145: 
