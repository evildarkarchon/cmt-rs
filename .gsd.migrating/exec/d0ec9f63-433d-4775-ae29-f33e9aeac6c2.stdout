153: def load_font(font_path: str) -> None:
154: 	# https://learn.microsoft.com/en-us/windows/win32/api/wingdi/nf-wingdi-addfontresourceexw
155: 	# FR_PRIVATE = 0x10
156: 	# FR_NOT_ENUM = 0x20
157: 	buffer = create_unicode_buffer(font_path)
158: 	windll.gdi32.AddFontResourceExW(byref(buffer), 0x10, 0)
