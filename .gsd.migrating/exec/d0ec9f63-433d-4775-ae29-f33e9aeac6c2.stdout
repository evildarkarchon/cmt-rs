40: class F4SETab(CMCTabFrame):
41: 	def __init__(self, cmc: CMCheckerInterface, notebook: ttk.Notebook) -> None:
42: 		super().__init__(cmc, notebook, "F4SE")
43: 		self.loading_text = "Scanning DLLs..."
44: 
45: 		self.dll_info: dict[str, DLLInfo | None] = {}
46: 
47: 	def _load(self) -> bool:
48: 		if self.cmc.game.data_path is None:
49: 			self.loading_error = "Data folder not found"
50: 			return False
51: 
52: 		if self.cmc.game.f4se_path is None:
53: 			self.loading_error = "Data/F4SE/Plugins folder not found"
54: 			if not self.cmc.game.manager:
55: 				self.loading_error += "\nTry launching via your mod manager."
56: 			return False
57: 
58: 		self.dll_info.clear()
59: 		for dll_file in self.cmc.game.f4se_path.iterdir():
60: 			if dll_file.suffix.lower() == ".dll" and not dll_file.name.startswith("msdia"):
61: 				logger.debug("Scanning %s", dll_file.name)
62: 				self.dll_info[dll_file.name] = parse_dll(dll_file)
63: 
64: 		return True
65: 
66: 	def _build_gui(self) -> None:
67: 		self.grid_columnconfigure(0, weight=0)
68: 		self.grid_columnconfigure(2, weight=1)
69: 		self.grid_rowconfigure(0, weight=0)
70: 		self.grid_rowconfigure(1, weight=1)
71: 
72: 		tree_dlls = ttk.Treeview(self, columns=("og", "ng", "ae", "user"))
73: 		tree_dlls.heading("#0", text="DLL")
74: 		tree_dlls.heading("og", text="OG")
75: 		tree_dlls.heading("ng", text="NG")
76: 		tree_dlls.heading("ae", text="AE")
77: 		tree_dlls.heading("user", text="Your Game")
78: 
79: 		tree_dlls.column("#0", width=240, stretch=False, anchor=E)
80: 		tree_dlls.column("og", width=60, stretch=False, anchor=CENTER)
81: 		tree_dlls.column("ng", width=60, stretch=False, anchor=CENTER)
82: 		tree_dlls.column("ae", width=60, stretch=False, anchor=CENTER)
83: 		tree_dlls.column("user", width=80, stretch=False, anchor=CENTER)
84: 
85: 		tree_dlls.tag_configure(TAG_NEUTRAL, foreground=COLOR_NEUTRAL_1)
86: 		tree_dlls.tag_configure(TAG_GOOD, foreground=COLOR_GOOD)
87: 		tree_dlls.tag_configure(TAG_BAD, foreground=COLOR_BAD)
88: 		tree_dlls.tag_configure(TAG_NOTE, foreground="yellow")
89: 
90: 		scroll_tree_y = ttk.Scrollbar(
91: 			self,
92: 			orient=VERTICAL,
93: 			command=tree_dlls.yview,  # pyright: ignore[reportUnknownArgumentType]
94: 		)
95: 
96: 		tree_dlls.grid(column=0, row=0, rowspan=2, sticky=NS)
97: 		scroll_tree_y.grid(column=1, row=0, rowspan=2, sticky=NS)
98: 		tree_dlls.configure(yscrollcommand=scroll_tree_y.set)
99: 
100: 		ttk.Label(
101: 			self,
102: 			text="F4SE DLLs",
103: 			font=FONT,
104: 			anchor=N,
105: 		).grid(column=2, row=0, padx=5, pady=5)
106: 
107: 		text_about_f4se = Text(
108: 			self,
109: 			font=FONT_SMALL,
110: 			wrap=CHAR,
111: 			relief=FLAT,
112: 		)
113: 		text_about_f4se.insert(END, ABOUT_F4SE_DLLS)
114: 		text_about_f4se.tag_add(TAG_NEUTRAL, "2.0", "2.18")
115: 		text_about_f4se.tag_add(TAG_GOOD, "6.0", "6.1")
116: 		text_about_f4se.tag_add(TAG_BAD, "8.0", "8.1")
117: 		text_about_f4se.tag_add(TAG_NEUTRAL, "10.0", "10.1")
118: 		text_about_f4se.tag_add(TAG_NOTE, "14.0", "14.1")
119: 		text_about_f4se.tag_configure(TAG_GOOD, foreground=COLOR_GOOD)
120: 		text_about_f4se.tag_configure(TAG_BAD, foreground=COLOR_BAD)
121: 		text_about_f4se.tag_configure(TAG_NEUTRAL, foreground=COLOR_NEUTRAL_2)
122: 		text_about_f4se.tag_configure(TAG_NOTE, foreground="yellow")
123: 		text_about_f4se.configure(state=DISABLED)
124: 		text_about_f4se.grid(column=2, row=1, sticky=NSEW, padx=0)
125: 
126: 		tag: str | None = None
127: 		for dll, info in self.dll_info.items():
128: 			values: list[str] = []
129: 			if info is None or not info["IsF4SE"]:
130: 				tag = TAG_NEUTRAL
131: 				values = [EMOJI_DLL_UNKNOWN] * 3
132: 			else:
133: 				og = EMOJI_DLL_GOOD if info.get("SupportsOG") else EMOJI_DLL_BAD
134: 
135: 				supports_ngae = info.get("SupportsNGAE")
136: 				supports_ng = info.get("SupportsNG")
137: 				supports_ae = info.get("SupportsAE")
138: 
139: 				if supports_ngae:
140: 					ng = EMOJI_DLL_NOTE if supports_ng is None else EMOJI_DLL_GOOD if supports_ng else EMOJI_DLL_BAD
141: 					ae = EMOJI_DLL_NOTE if supports_ae is None else EMOJI_DLL_GOOD if supports_ae else EMOJI_DLL_BAD
142: 
143: 				else:
144: 					ng = EMOJI_DLL_BAD
145: 					ae = EMOJI_DLL_BAD
146: 					# cg = EMOJI_DLL_GOOD if self.cmc.game.is_foog() else EMOJI_DLL_BAD
147: 
148: 				cg = "\N{CROSS MARK}"
149: 				if self.cmc.game.is_foae():
150: 					cg = EMOJI_DLL_GOOD if supports_ae else EMOJI_DLL_NOTE if supports_ngae else "\N{CROSS MARK}"
151: 
152: 				elif self.cmc.game.is_foog():
153: 					cg = EMOJI_DLL_GOOD if info.get("SupportsOG") else "\N{CROSS MARK}"
154: 
155: 				elif self.cmc.game.is_fong():
156: 					cg = EMOJI_DLL_GOOD if supports_ng else EMOJI_DLL_NOTE if supports_ngae else "\N{CROSS MARK}"
157: 
158: 				values = [og, ng, ae, cg]
159: 				tag = TAG_NOTE if cg == EMOJI_DLL_NOTE else TAG_GOOD if cg == EMOJI_DLL_GOOD else TAG_BAD
160: 
161: 			tree_dlls.insert("", END, text=dll, values=values, tags=tag)

