    domain::discovery::{
        ArchiveFormat, ArchiveRecord, ArchiveVersion, Fallout4IniFiles, Fallout4InstallType,
        Fallout4Installation, ModuleHeaderVersion, ModuleKind, ModuleRecord,
    },
    platform::{
        PlatformError, PlatformErrorKind,
