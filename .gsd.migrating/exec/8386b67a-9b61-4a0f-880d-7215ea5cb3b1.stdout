630: 
631:         // Add a segment
632:         cache.add( 3, 1, &mut data,0,0).unwrap();
633:         cache.add( 0, 2, &mut data,0,0).unwrap();
634:         cache.add( 2, 2, &mut data,0,0).unwrap();
635: 
636:         // Retrieve the segment
