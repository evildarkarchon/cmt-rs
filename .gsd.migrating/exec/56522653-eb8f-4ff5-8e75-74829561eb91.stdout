2047:         },
2048:         tools::{
2049:             ABOUT_COPY_INVITE_LABEL, ABOUT_COPY_LINK_LABEL, ABOUT_COPY_SUCCESS_LABEL,
2050:             ABOUT_CREDIT_LABEL, ABOUT_LINKS, ABOUT_TITLE_LABEL, AboutActionId, AboutLinkId,
2051:             IMAGE_RESOURCE_PATHS, TOOL_GROUPS, ToolActionId,
