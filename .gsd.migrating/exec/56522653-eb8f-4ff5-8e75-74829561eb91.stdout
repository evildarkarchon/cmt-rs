2053:     };
2054: 
2055:     const MAIN_SLINT: &str = include_str!("../ui/main.slint");
2056:     const SETTINGS_SLINT: &str = include_str!("../ui/settings_tab.slint");
2057:     const OVERVIEW_SLINT: &str = include_str!("../ui/overview_tab.slint");
2058:     const F4SE_SLINT: &str = include_str!("../ui/f4se_tab.slint");
2059:     const TOOLS_SLINT: &str = include_str!("../ui/tools_tab.slint");
2060:     const ABOUT_SLINT: &str = include_str!("../ui/about_tab.slint");
2061:     const TAB_COMPONENTS: [(&str, &str, &str, &str); 6] = [
2062:         (
2063:             "ui/overview_tab.slint",
2064:             "OverviewTab",
2065:             "Overview",
2066:             OVERVIEW_SLINT,
2067:         ),
2068:         ("ui/f4se_tab.slint", "F4seTab", "F4SE", F4SE_SLINT),
2069:         (
2070:             "ui/scanner_tab.slint",
2071:             "ScannerTab",
2072:             "Scanner",
2073:             include_str!("../ui/scanner_tab.slint"),
2074:         ),
2075:         ("ui/tools_tab.slint", "ToolsTab", "Tools", TOOLS_SLINT),
2076:         (
2077:             "ui/settings_tab.slint",
2078:             "SettingsTab",
2079:             "Settings",
2080:             SETTINGS_SLINT,
2081:         ),
2082:         ("ui/about_tab.slint", "AboutTab", "About", ABOUT_SLINT),
2083:     ];
2084:     const INERT_TAB_COMPONENTS: [(&str, &str, &str, &str); 1] = [TAB_COMPONENTS[2]];
2085: 
2086:     fn slint_string_property_values(source: &str, property: &str) -> Vec<String> {
2087:         let prefix = format!("{property}:");
2088: 
2089:         source
2090:             .lines()
2091:             .filter_map(|line| line.trim().strip_prefix(&prefix))
2092:             .filter_map(|value| value.trim().trim_end_matches(';').strip_prefix('"'))
2093:             .filter_map(|value| value.strip_suffix('"'))
2094:             .map(String::from)
2095:             .collect()
2096:     }
2097: 
2098:     fn assert_source_contains_in_order(source: &str, expected: &[&str]) {
2099:         let mut search_from = 0;
2100: 
2101:         for value in expected {
2102:             let relative_index = source[search_from..].find(value).unwrap_or_else(|| {
2103:                 panic!("expected source to contain {value:?} after byte {search_from}")
2104:             });
2105:             search_from += relative_index + value.len();
2106:         }
2107:     }
2108: 
2109:     fn assert_source_contains_strings_in_order(source: &str, expected: &[String]) {
2110:         let mut search_from = 0;
2111: 
2112:         for value in expected {
2113:             let relative_index = source[search_from..].find(value).unwrap_or_else(|| {
2114:                 panic!("expected source to contain {value:?} after byte {search_from}")
2115:             });
2116:             search_from += relative_index + value.len();
2117:         }
2118:     }
2119: 
2120:     fn slint_string_literal(value: &str) -> String {
2121:         value
2122:             .replace('\\', "\\\\")
2123:             .replace('\n', "\\n")
2124:             .replace('"', "\\\"")
2125:     }
2126: 
2127:     fn slint_assignment(property: &str, value: &str) -> String {
2128:         format!("{property}: \"{}\"", slint_string_literal(value))
2129:     }
2130: 
2131:     fn slint_image_reference(resource_path: &str) -> String {
2132:         format!("@image-url(\"../{resource_path}\")")
2133:     }
