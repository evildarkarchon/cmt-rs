130: /// Manager-specific discovery failures.
131: #[derive(Debug, Clone, PartialEq, Eq)]
132: pub enum ModManagerDiscoveryError {
133:     /// Process-table inspection failed before a manager could be classified.
134:     ProcessInspection(PlatformError),
135:     /// A matching manager process did not expose an executable path.
136:     MissingExecutablePath {
137:         /// Manager kind inferred from the process name.
138:         kind: ModManagerKind,
139:         /// Process id that matched the manager executable name.
140:         pid: u32,
141:     },
142:     /// MO2 was detected but its configuration was unavailable or invalid.
143:     ModOrganizer(Mo2ParseError),
144: }
145: 
146: impl ModManagerDiscoveryError {
147:     /// Returns safe user-facing text for this manager failure.
148:     pub fn user_message(&self) -> String {
149:         match self {
150:             Self::ProcessInspection(error) => error.user_message().to_owned(),
151:             Self::MissingExecutablePath { kind, .. } => format!(
152:                 "{} was detected but its executable path could not be read.",
153:                 kind.display_name()
154:             ),
155:             Self::ModOrganizer(error) => error.user_message(),
156:         }
157:     }
158: 
159:     /// Returns true when game discovery should stop rather than silently falling through.
160:     pub const fn blocks_game_discovery(&self) -> bool {
161:         matches!(
162:             self,
163:             Self::MissingExecutablePath { .. } | Self::ModOrganizer(_)
164:         )
165:     }
166: 
167:     /// Returns whether the failure should be handled without panicking.
168:     pub const fn is_recoverable(&self) -> bool {
169:         true
170:     }
171: }
172: 
173: impl fmt::Display for ModManagerDiscoveryError {
174:     fn fmt(&self, formatter: &mut fmt::Formatter<'_>) -> fmt::Result {
175:         formatter.write_str(&self.user_message())
176:     }
177: }
178: 
179: impl std::error::Error for ModManagerDiscoveryError {}

