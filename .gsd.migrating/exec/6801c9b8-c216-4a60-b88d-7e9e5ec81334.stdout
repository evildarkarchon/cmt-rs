541:     }
542: 
543:     fn discover_mod_organizer(
544:         &self,
545:         manager: DetectedModManager,
546:         request: &DiscoveryRequest,
547:         steps: &mut Vec<ModManagerDiscoveryStep>,
548:     ) -> Result<Mo2Configuration, Mo2ParseError> {
549:         let manager_directory = manager
550:             .executable_path
551:             .parent()
552:             .map(Path::to_path_buf)
553:             .unwrap_or_default();
554:         let portable_ini_path = manager_directory.join("ModOrganizer.ini");
555:         let portable_ini_exists = self.mo2_file_exists(
556:             &portable_ini_path,
557:             steps,
558:             ModManagerDiscoveryStage::PortableIni,
559:         )?;
560:         let portable_txt_path = manager_directory.join("portable.txt");
561:         let portable_txt_exists = self.mo2_file_exists(
562:             &portable_txt_path,
563:             steps,
564:             ModManagerDiscoveryStage::PortableMarker,
565:         )?;
566: 
567:         if portable_txt_exists {
568:             if !portable_ini_exists {
569:                 return Err(Mo2ParseError::portable_marker_without_ini());
570:             }
571:             return self.parse_mo2_ini(manager, &portable_ini_path, Some(portable_txt_path), true);
572:         }
573: 
574:         if let Some(current_instance) = self.read_mo2_current_instance(steps) {
575:             if let Some(local_appdata) = &request.local_appdata {
576:                 let instance_ini_path = local_appdata
577:                     .join("ModOrganizer")
578:                     .join(current_instance)
579:                     .join("ModOrganizer.ini");
580:                 let instance_ini_exists = self.mo2_file_exists(
581:                     &instance_ini_path,
582:                     steps,
583:                     ModManagerDiscoveryStage::LocalAppDataInstanceIni,
584:                 )?;
585:                 if instance_ini_exists {
586:                     let configuration =
587:                         self.parse_mo2_ini(manager.clone(), &instance_ini_path, None, false)?;
588:                     if configuration.context.game_path.is_some() {
589:                         return Ok(configuration);
590:                     }
591:                 }
592:             } else {
593:                 steps.push(ModManagerDiscoveryStep::new(
594:                     ModManagerDiscoveryStage::LocalAppDataInstanceIni,
595:                     "LOCALAPPDATA unavailable",
596:                     ModManagerDiscoveryStepOutcome::Skipped,
597:                 ));
598:             }
599:         }
600: 
601:         if !portable_ini_exists {
602:             steps.push(ModManagerDiscoveryStep::new(
603:                 ModManagerDiscoveryStage::FallbackPortableIni,
604:                 portable_ini_path.display().to_string(),
605:                 ModManagerDiscoveryStepOutcome::Missing,
606:             ));
607:             return Err(Mo2ParseError::missing_mod_organizer_ini());
608:         }
609: 
610:         steps.push(ModManagerDiscoveryStep::new(
611:             ModManagerDiscoveryStage::FallbackPortableIni,
612:             portable_ini_path.display().to_string(),
613:             ModManagerDiscoveryStepOutcome::Found,
614:         ));
615:         self.parse_mo2_ini(manager, &portable_ini_path, None, true)
616:     }
617: 
618:     fn mo2_file_exists(
619:         &self,
620:         path: &Path,
621:         steps: &mut Vec<ModManagerDiscoveryStep>,
622:         stage: ModManagerDiscoveryStage,
623:     ) -> Result<bool, Mo2ParseError> {

-- parse_mo2_ini_values
695:         ini_path: &Path,
696:         portable_txt_path: Option<PathBuf>,
697:         portable: bool,
698:     ) -> Result<Mo2Configuration, Mo2ParseError> {
699:         let text = self
700:             .filesystem
701:             .read_to_string(ini_path)
702:             .map_err(mo2_missing_ini_with_diagnostic)?;
703:         let values = parse_mo2_ini_values(&text);
704:         let game_name = values
705:             .general
706:             .get("gameName")
707:             .map(String::as_str)
708:             .unwrap_or("Fallout 4");
709:         if game_name != "Fallout 4" {
710:             return Err(Mo2ParseError::unsupported_game_name(game_name, ini_path));
711:         }
712: 
713:         let Some(selected_profile) = values.general.get("selected_profile").cloned() else {
714:             return Err(Mo2ParseError::missing_selected_profile());
715:         };
716: 
717:         let base_directory = values
718:             .settings
719:             .get("base_directory")
720:             .map(|value| PathBuf::from(unwrap_mo2_value(value)))
721:             .unwrap_or_else(|| ini_path.parent().map(Path::to_path_buf).unwrap_or_default());
722:         let cache_directory = resolve_mo2_path(
723:             values.settings.get("cache_directory"),
724:             &base_directory,
725:             "%BASE_DIR%/webcache",
726:         );
727:         let download_directory = resolve_mo2_path(
728:             values.settings.get("download_directory"),
729:             &base_directory,
730:             "%BASE_DIR%/downloads",
731:         );
732:         let mod_directory = resolve_mo2_path(
733:             values.settings.get("mod_directory"),
734:             &base_directory,
735:             "%BASE_DIR%/mods",
736:         );
737:         let overwrite_directory = resolve_mo2_path(
738:             values.settings.get("overwrite_directory"),
739:             &base_directory,
740:             "%BASE_DIR%/overwrite",
741:         );
742:         let profiles_directory = resolve_mo2_path(
743:             values.settings.get("profiles_directory"),
744:             &base_directory,
745:             "%BASE_DIR%/profiles",
746:         );
747: 
748:         if path_is_empty(&mod_directory)
749:             || path_is_empty(&profiles_directory)
750:             || path_is_empty(&overwrite_directory)
751:         {
752:             return Err(Mo2ParseError::missing_stage_settings(
753:                 Some(mod_directory),
754:                 Some(profiles_directory),
755:                 Some(selected_profile),
756:                 Some(overwrite_directory),
757:             ));
758:         }
759: 
760:         let directories = ModOrganizerDirectories::new(
761:             base_directory,
762:             cache_directory,
763:             download_directory,
764:             mod_directory,
765:             overwrite_directory,
766:             profiles_directory,
767:         );
768:         let profile_local_inis = values
769:             .settings
770:             .get("profile_local_inis")
771:             .is_some_and(|value| parse_mo2_bool(value));
772:         let profile_local_saves = values
773:             .settings
774:             .get("profile_local_saves")
775:             .is_some_and(|value| parse_mo2_bool(value));
776:         let skip_file_suffixes = values
777:             .settings
778:             .get("skip_file_suffixes")
779:             .map(|value| parse_csv_list(&unwrap_mo2_value(value)))
780:             .unwrap_or_else(|| vec![".mohidden".to_owned()]);
781:         let skip_directories = values
782:             .settings
783:             .get("skip_directories")

