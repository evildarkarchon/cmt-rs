857:                 );
858:                 false
859:             }
860:         }
861:     }
862: 
863:     fn discover_game(
864:         &self,
865:         manager_game_path: Option<PathBuf>,
866:         request: &DiscoveryRequest,
867:     ) -> (
868:         Result<Fallout4Installation, DiscoveryError>,
869:         Vec<DiscoveryAttempt>,
870:     ) {
871:         let mut attempts = Vec::new();
872:         let mut diagnostics = Vec::new();
873: 
874:         if let Some(candidate) = manager_game_path {
875:             match self.evaluate_game_candidate(DiscoverySource::RunningManagerGamePath, candidate) {
876:                 CandidateEvaluation::Accepted(installation, attempt) => {
877:                     attempts.push(attempt);
878:                     return (Ok(*installation), attempts);
879:                 }
880:                 CandidateEvaluation::Rejected(attempt) => attempts.push(attempt),
881:                 CandidateEvaluation::AdapterError(attempt, diagnostic) => {
882:                     diagnostics.push(diagnostic);
883:                     attempts.push(attempt);
884:                 }
885:             }
886:         } else {
887:             attempts.push(DiscoveryAttempt::no_candidate(
888:                 DiscoverySource::RunningManagerGamePath,
889:             ));
890:         }
891: 
892:         match self.evaluate_game_candidate(
893:             DiscoverySource::CurrentWorkingDirectory,
894:             request.current_working_directory.clone(),
895:         ) {
896:             CandidateEvaluation::Accepted(installation, attempt) => {
897:                 attempts.push(attempt);
898:                 return (Ok(*installation), attempts);
899:             }
900:             CandidateEvaluation::Rejected(attempt) => attempts.push(attempt),
901:             CandidateEvaluation::AdapterError(attempt, diagnostic) => {
902:                 diagnostics.push(diagnostic);
903:                 attempts.push(attempt);
904:             }
905:         }
906: 
907:         if let Some(outcome) = self.evaluate_registry_candidate(
908:             DiscoverySource::BethesdaRegistry,
909:             RegistryValueRequest::new(
910:                 RegistryHive::LocalMachine,
911:                 BETHESDA_FALLOUT4_REGISTRY_SUBKEY,
912:                 BETHESDA_FALLOUT4_REGISTRY_VALUE,
913:             ),
914:             &mut diagnostics,
915:         ) {
916:             match outcome {
917:                 RegistryCandidateOutcome::Accepted(installation, attempt) => {
918:                     attempts.push(attempt);
919:                     return (Ok(*installation), attempts);
920:                 }
921:                 RegistryCandidateOutcome::Rejected { attempt, error } => {
922:                     attempts.push(attempt);
923:                     return (Err(error), attempts);
924:                 }
925:                 RegistryCandidateOutcome::NoCandidate(attempt)
926:                 | RegistryCandidateOutcome::AdapterError(attempt) => attempts.push(attempt),
927:             }
928:         }
929: 
930:         if let Some(outcome) = self.evaluate_registry_candidate(
931:             DiscoverySource::GogRegistry,
932:             RegistryValueRequest::new(
933:                 RegistryHive::LocalMachine,
934:                 GOG_FALLOUT4_REGISTRY_SUBKEY,
935:                 GOG_FALLOUT4_REGISTRY_VALUE,
936:             ),
937:             &mut diagnostics,
938:         ) {
939:             match outcome {
940:                 RegistryCandidateOutcome::Accepted(installation, attempt) => {
941:                     attempts.push(attempt);
942:                     return (Ok(*installation), attempts);
943:                 }

