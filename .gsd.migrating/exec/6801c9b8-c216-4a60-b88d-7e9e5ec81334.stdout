354:     /// Runs manager, game-path, and system metadata discovery without UI prompts.
355:     pub fn discover(&self, request: &DiscoveryRequest) -> DiscoveryReport {
356:         let system_metadata = self.process.system_metadata().inspect_err(|error| {
357:             tracing::warn!(
358:                 event = "discovery-system-metadata-error",
359:                 operation = %error.operation,
360:                 kind = ?error.kind,
361:                 target = %error.target,
362:                 "System metadata discovery failed"
363:             );
364:         });
365: 
366:         let mut manager_steps = Vec::new();
367:         let mod_manager = self.discover_mod_manager(request, &mut manager_steps);
368:         let manager_game_path = match &mod_manager {
369:             Ok(Some(manager)) => manager.manager_game_path(),
370:             Ok(None) => None,
371:             Err(error) if error.blocks_game_discovery() => {
372:                 tracing::warn!(
373:                     event = "discovery-manager-blocked-game-discovery",
374:                     error = %error,
375:                     "Manager-specific discovery failure blocked fallback probing"
376:                 );
377:                 let attempts = vec![DiscoveryAttempt::adapter_error(
378:                     DiscoverySource::RunningManagerGamePath,
379:                     None,
380:                     PlatformError::command_failed(
381:                         PlatformOperation::ReadFile,
382:                         "mod-manager discovery",
383:                         error.to_string(),
384:                     ),
385:                 )];
386:                 return DiscoveryReport {
387:                     game: Err(DiscoveryError::fallout4_not_found(Some(error.to_string()))),
388:                     mod_manager,
389:                     system_metadata,
390:                     attempts,
391:                     manager_steps,
392:                 };
393:             }
394:             Err(error) => {
395:                 tracing::warn!(
396:                     event = "discovery-manager-nonblocking-error",
397:                     error = %error,
398:                     "Manager discovery failed; continuing fallback game-path probing"
399:                 );
400:                 None
401:             }
402:         };
403: 
404:         let (game, attempts) = self.discover_game(manager_game_path, request);
405: 
406:         DiscoveryReport {
407:             game,
408:             mod_manager,
409:             system_metadata,
410:             attempts,
411:             manager_steps,
412:         }
413:     }
414: 
415:     fn discover_mod_manager(
416:         &self,
417:         request: &DiscoveryRequest,
418:         steps: &mut Vec<ModManagerDiscoveryStep>,
419:     ) -> Result<Option<DiscoveredModManager>, ModManagerDiscoveryError> {
420:         let Some(manager) = self.detect_running_manager(request, steps)? else {
421:             return Ok(None);
422:         };
423: 
424:         match manager.kind {
425:             ModManagerKind::ModOrganizer => self
426:                 .discover_mod_organizer(manager, request, steps)
427:                 .map(|configuration| {
428:                     Some(DiscoveredModManager::ModOrganizer(Box::new(configuration)))
429:                 })
430:                 .map_err(ModManagerDiscoveryError::ModOrganizer),
431:             ModManagerKind::Vortex => {
432:                 steps.push(ModManagerDiscoveryStep::new(
433:                     ModManagerDiscoveryStage::VortexIdentity,
434:                     manager.executable_path.display().to_string(),
435:                     ModManagerDiscoveryStepOutcome::Found,

