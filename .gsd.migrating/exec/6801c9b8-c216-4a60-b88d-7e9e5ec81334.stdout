1089:     fn is_fo4_dir(&self, path: &Path) -> Result<bool, PlatformError> {
1090:         if !self.filesystem.is_dir(path)? {
1091:             return Ok(false);
1092:         }
1093:         self.filesystem.is_file(&path.join(FALLOUT4_EXECUTABLE))
