443: 
444:     fn detect_running_manager(
445:         &self,
446:         request: &DiscoveryRequest,
447:         steps: &mut Vec<ModManagerDiscoveryStep>,
448:     ) -> Result<Option<DetectedModManager>, ModManagerDiscoveryError> {
449:         let Some(current_pid) = request.current_process_id else {
450:             steps.push(ModManagerDiscoveryStep::new(
451:                 ModManagerDiscoveryStage::ProcessAncestry,
452:                 "current process id unavailable",
453:                 ModManagerDiscoveryStepOutcome::Skipped,
454:             ));
455:             tracing::debug!(
456:                 event = "mod-manager-detection-skipped",
457:                 reason = "missing-current-process-id"
458:             );
459:             return Ok(None);
460:         };
461: 
462:         let processes = self.process.list_processes().map_err(|error| {
463:             steps.push(ModManagerDiscoveryStep::new(
464:                 ModManagerDiscoveryStage::ProcessAncestry,
465:                 "process table",
466:                 ModManagerDiscoveryStepOutcome::Error,
467:             ));
468:             ModManagerDiscoveryError::ProcessInspection(error)
469:         })?;
470:         let processes_by_pid = processes
471:             .into_iter()
472:             .map(|process| (process.pid, process))
473:             .collect::<BTreeMap<_, _>>();
474: 
475:         let mut maybe_pid = processes_by_pid
476:             .get(&current_pid)
477:             .and_then(|process| process.parent_pid);
478: 
479:         for depth in 0..PROCESS_ANCESTOR_LIMIT {
480:             let Some(pid) = maybe_pid else {
481:                 break;
482:             };
483:             let Some(process) = processes_by_pid.get(&pid) else {
484:                 break;
485:             };
486:             if let Some(kind) = manager_kind_from_process_name(&process.name) {
487:                 let Some(executable_path) = process.executable_path.clone() else {
488:                     steps.push(ModManagerDiscoveryStep::new(
489:                         ModManagerDiscoveryStage::ProcessAncestry,
490:                         format!("pid {pid} {}", process.name),
491:                         ModManagerDiscoveryStepOutcome::Error,
492:                     ));
493:                     return Err(ModManagerDiscoveryError::MissingExecutablePath { kind, pid });
494:                 };
495:                 let version = self.manager_version_or_zero(&executable_path);
496:                 steps.push(ModManagerDiscoveryStep::new(
497:                     ModManagerDiscoveryStage::ProcessAncestry,
498:                     format!("pid {pid} {}", executable_path.display()),
499:                     ModManagerDiscoveryStepOutcome::Found,
500:                 ));
501:                 tracing::info!(
502:                     event = "mod-manager-detected",
503:                     manager = kind.display_name(),
504:                     executable_path = %executable_path.display(),
505:                     version = %version,
506:                     depth,
507:                     "Detected supported mod manager in process ancestry"
508:                 );
509:                 return Ok(Some(DetectedModManager::new(
510:                     kind,
511:                     executable_path,
512:                     version,
513:                 )));
514:             }
515:             maybe_pid = process.parent_pid;
516:         }
517: 
518:         steps.push(ModManagerDiscoveryStep::new(
519:             ModManagerDiscoveryStage::ProcessAncestry,
520:             format!("parent chain for pid {current_pid}"),
521:             ModManagerDiscoveryStepOutcome::Missing,
522:         ));
523:         Ok(None)
524:     }

