1096:     fn installation_for_game_path(&self, game_path: PathBuf) -> Fallout4Installation {
1097:         let data_candidate = game_path.join("Data");
1098:         let data_path = self.optional_directory(&data_candidate);
1099:         let f4se_plugins_path = data_path
1100:             .as_ref()
1101:             .and_then(|data_path| self.optional_directory(&data_path.join("F4SE").join("Plugins")));
1102: 
1103:         Fallout4Installation::with_optional_paths(game_path, data_path, f4se_plugins_path)
1104:     }
1105: 
1106:     fn optional_directory(&self, path: &Path) -> Option<PathBuf> {
1107:         match self.filesystem.is_dir(path) {
1108:             Ok(true) => Some(path.to_path_buf()),
1109:             Ok(false) => None,
1110:             Err(error) => {
1111:                 tracing::warn!(
1112:                     event = "derived-path-check-error",
1113:                     operation = %error.operation,
1114:                     kind = ?error.kind,
1115:                     target = %error.target,
1116:                     "Optional derived path could not be checked; representing it as missing"
1117:                 );
1118:                 None
1119:             }
1120:         }
1121:     }
1122: }
