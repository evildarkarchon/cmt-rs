1142: #[derive(Debug, Default, Clone, PartialEq, Eq)]
1143: struct RawMo2IniValues {
1144:     general: BTreeMap<String, String>,
1145:     settings: BTreeMap<String, String>,
1146:     custom_executable_binaries: Vec<String>,
1147: }
1148: 
1149: fn parse_mo2_ini_values(text: &str) -> RawMo2IniValues {
1150:     let mut values = RawMo2IniValues::default();
1151:     let mut section: Option<&str> = None;
1152: 
1153:     for raw_line in text.lines() {
1154:         let line = raw_line.trim();
1155:         if line.starts_with('[') {
1156:             section = match line {
1157:                 "[General]" => Some("General"),
1158:                 "[Settings]" => Some("Settings"),
1159:                 "[customExecutables]" => Some("customExecutables"),
1160:                 _ => None,
1161:             };
1162:             continue;
1163:         }
1164:         let Some(active_section) = section else {
1165:             continue;
1166:         };
1167:         let Some((setting, value)) = line.split_once('=') else {
1168:             continue;
1169:         };
1170:         match active_section {
1171:             "General" if matches!(setting, "gameName" | "gamePath" | "selected_profile") => {
1172:                 values
1173:                     .general
1174:                     .insert(setting.to_owned(), unwrap_mo2_value(value));
1175:             }
1176:             "Settings" if is_supported_mo2_setting(setting) => {
1177:                 values
1178:                     .settings
1179:                     .insert(setting.to_owned(), unwrap_mo2_value(value));
1180:             }
1181:             "customExecutables" if setting.ends_with("binary") => {
1182:                 values.custom_executable_binaries.push(value.to_owned());
1183:             }
1184:             _ => {}
1185:         }
1186:     }

