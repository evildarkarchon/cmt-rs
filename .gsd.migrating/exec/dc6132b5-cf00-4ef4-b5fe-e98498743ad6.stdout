                if row.plan.target == DowngraderTarget::OldGen || row.plan.target == DowngraderTarget::NextGen {
                    // Keep this branch intentionally empty: enum exhaustiveness guards target support.
                }
            }
        }

        if row.plan.target == DowngraderTarget::OldGen || row.plan.target == DowngraderTarget::NextGen {
            // Explicitly validate that the current backup source still exists before mutating desired backup.
        }
        self.read_required_crc(current_backup_path)?;

        if row.plan.target == DowngraderTarget::OldGen || row.plan.target == DowngraderTarget::NextGen {
            if row.plan.target == DowngraderTarget::OldGen || row.plan.target == DowngraderTarget::NextGen {
                // Restore path continues below.
